"},{"callback":"scene6_set2_lr","eventType":"onLongPressReleased","name":"scene6_set2"},{"callback":"select_motion_setup","eventType":"onToggled","name":"select_motion_setup"},{"callback":"select_profile_setup","eventType":"onToggled","name":"select_profile_setup"},{"callback":"p1_on","eventType":"onToggled","name":"p1_on"},{"callback":"p1_on_delay","eventType":"onToggled","name":"p1_on_delay"},{"callback":"p1_off","eventType":"onToggled","name":"p1_off"},{"callback":"p1_off_delay","eventType":"onToggled","name":"p1_off_delay"},{"callback":"p1_cha","eventType":"onToggled","name":"p1_cha"},{"callback":"p1_cha_delay","eventType":"onToggled","name":"p1_cha_delay"},{"callback":"p1_time_n","eventType":"onReleased","name":"p1_time_n"},{"callback":"p1_time_n_ld","eventType":"onLongPressDown","name":"p1_time_n"},{"callback":"p1_time_n_lr","eventType":"onLongPressReleased","name":"p1_time_n"},{"callback":"p1_time_p","eventType":"onReleased","name":"p1_time_p"},{"callback":"p1_time_p_ld","eventType":"onLongPressDown","name":"p1_time_p"},{"callback":"p1_time_p_lr","eventType":"onLongPressReleased","name":"p1_time_p"},{"callback":"unused1","eventType":"onReleased","name":"unused1"},{"callback":"","eventType":"onLongPressDown","name":"unused1"},{"callback":"","eventType":"onLongPressReleased","name":"unused1"},{"callback":"p1_time_cha","eventType":"onReleased","name":"p1_time_cha"},{"callback":"p1_time_cha_ld","eventType":"onLongPressDown","name":"p1_time_cha"},{"callback":"p1_time_cha_lr","eventType":"onLongPressReleased","name":"p1_time_cha"},{"callback":"p1_time_minsec","eventType":"onReleased","name":"p1_time_minsec"},{"callback":"p1_time_minsec_ld","eventType":"onLongPressDown","name":"p1_time_minsec"},{"callback":"p1_time_minsec_lr","eventType":"onLongPressReleased","name":"p1_time_minsec"},{"callback":"unused2","eventType":"onReleased","name":"unused2"},{"callback":"","eventType":"onLongPressDown","name":"unused2"},{"callback":"","eventType":"onLongPressReleased","name":"unused2"}],"quickAppVariables":[{"name":"color1","type":"string","value":"#ff9933"},{"name":"color4","type":"string","value":"#66ffff"},{"name":"color3","type":"string","value":"#990000"},{"name":"Scene4","type":"string","value":"Dinner"},{"name":"roomID","type":"string","value":""},{"name":"language","type":"string","value":"en"},{"name":"Setup","type":"string","value":"0"},{"name":"Scene5","type":"string","value":"Night"},{"name":"color2","type":"string","value":"#99ff33"},{"name":"Scene2","type":"string","value":"Dim"},{"name":"Scene1","type":"string","value":"100%"},{"name":"Scene6","type":"string","value":"qvars"},{"name":"Scene3","type":"string","value":"Movie"}],"typeTemplateInitialized":true,"userDescription":"Profile Light controller \nMade by Joachim Brørs Sommerfeld, Norway\njoachim.brors.sommerfeld@gmail.com\nI am not a programer by craft/work, it is only a hobby so the code isnt perfect :D \nUse at own risk! ^^\n\nThis quickapp also uses the Eventlib made by:\neventLib©️jan@gabrielsson.com\nAnd wouldnt work without it! Thanks!"},"initialInterfaces":["quickApp"],"files":[{"name":"main","isMain":true,"isOpen":true,"content":"\n\n---@diagnostic disable\n--%%name=Profile Light Controller\n--%%type=com.fibaro.genericDevice\n\n\n--%%id=109\n--proxy=\"Easylightproxy\"\n\n\n-----OK\n--%%u={label=\"s0\",text=\"\"}\n--%%u={{switch=\"turnoff\",text=\"turnoff\",visible=true,onReleased=\"turnoff\"},{switch=\"turnon\",text=\"turnon\",visible=true,onReleased=\"turnon\"}}\n--%%u={{switch=\"scene1_set\",text=\"scene1_set\",visible=true,onReleased=\"scene1_set\"},{switch=\"scene2_set\",text=\"scene2_set\",visible=true,onReleased=\"scene2_set\"}}\n--%%u={{switch=\"scene3_set\",text=\"scene3_set\",visible=true,onReleased=\"scene3_set\"},{switch=\"scene4_set\",text=\"scene4_set\",visible=true,onReleased=\"scene4_set\"}}\n--%%u={{switch=\"scene5_set\",text=\"scene5_set\",visible=true,onReleased=\"scene5_set\"},{switch=\"scene6_set\",text=\"scene6_set\",visible=true,onReleased=\"scene6_set\"}}\n\n\n-----OK\n--%%u={label=\"infoLine2\",text=\"\"}\n--%%u={label=\"info_pir_enable\",text=\"info_pir_enable\"}\n--%%u={{switch=\"disable\",text=\"disable\",visible=true,onReleased=\"disable\"},{switch=\"enable\",text=\"enable\",visible=true,onReleased=\"enable\"}}\n\n-----OK\n--%%u={label=\"infoLine4\",text=\"infoLine4\"}\n--%%u={button=\"save_lights\",text=\"save_lights\",visible=true,onReleased=\"save_lights\"}\n--%%u={multi=\"select_light_setup\",text=\"Light List\",onToggled=\"select_light_setup\",options={}}\n--%%u={label=\"info_selectlight\",text=\"info_selectlight\"}\n\n-----OK\n--%%u={label=\"infoLine5\",text=\" infoLine5\"}\n--%%u={{switch=\"scene1_save\",text=\"scene1_save\",visible=true,onLongPressDown=\"scene1_save\"},{switch=\"scene1_set2\",text=\"scene1_set2\",visible=true,onReleased=\"scene1_set2\"}}\n--%%u={label=\"scene1_info\",text=\"scene1_info\"}\n--%%u={{switch=\"scene2_save\",text=\"scene2_save\",visible=true,onLongPressDown=\"scene2_save\"},{switch=\"scene2_set2\",text=\"scene2_set2\",visible=true,onReleased=\"scene2_set2\"}}\n--%%u={label=\"scene2_info\",text=\"scene2_info\"}\n--%%u={{switch=\"scene3_save\",text=\"scene3_save\",visible=true,onLongPressDown=\"scene3_save\"},{switch=\"scene3_set2\",text=\"scene3_set2\",visible=true,onReleased=\"scene3_set2\"}}\n--%%u={label=\"scene3_info\",text=\"scene3_info\"}\n--%%u={{switch=\"scene4_save\",text=\"scene4_save\",visible=true,onLongPressDown=\"scene4_save\"},{switch=\"scene4_set2\",text=\"scene4_set2\",visible=true,onReleased=\"scene4_set2\"}}\n--%%u={label=\"scene4_info\",text=\"scene4_info\"}\n--%%u={{switch=\"scene5_save\",text=\"scene5_save\",visible=true,onLongPressDown=\"scene5_save\"},{switch=\"scene5_set2\",text=\"scene5_set2\",visible=true,onReleased=\"scene5_set2\"}}\n--%%u={label=\"scene5_info\",text=\"scene5_info\"}\n--%%u={{switch=\"scene6_save\",text=\"scene6_save\",visible=true,onLongPressDown=\"scene6_save\"},{switch=\"scene6_set2\",text=\"scene6_set2\",visible=true,onReleased=\"scene6_set2\"}}\n--%%u={label=\"scene6_info\",text=\"scene6_info\"}\n\n\n-----OK\n--%%u={label=\"infoLine6\",text=\"\"}\n--%%u={multi=\"select_motion_setup\",text=\"Sensors\",onToggled=\"select_motion_setup\",options={}}\n--%%u={label=\"info_motionsensor\",text=\"info_motionsensor\"}\n\n\n\n-----ok   profile multiselect\n--%%u={label=\"infoLine7\",text=\"\"}\n--%%u={label=\"profile_info\",text=\"profile_info\"}\n--%%u={select=\"select_profile_setup\",text=\"Profiles\",onToggled=\"select_profile_setup\",options={}}\n\n-----OK\n--%%u={label=\"infoLine8\",text=\"\"}\n\n--%%u={label=\"p1_on_info\",text=\"p1_on_info\"}\n--%%u={select=\"p1_on\",text=\"p1_on\",onToggled=\"p1_on\",options={}}\n--%%u={select=\"p1_on_delay\",text=\"p1_on_delay\",onToggled=\"p1_on_delay\",options={}}\n\n--%%u={label=\"p1_off_info\",text=\"p1_off_info\"}\n--%%u={select=\"p1_off\",text=\"p1_off\",onToggled=\"p1_off\",options={}}\n--%%u={select=\"p1_off_delay\",text=\"p1_off_delay\",onToggled=\"p1_off_delay\",options={}}\n\n--%%u={label=\"p1_cha_info\",text=\"p1_cha_info\"}\n--%%u={select=\"p1_cha\",text=\"p1_cha\",onToggled=\"p1_cha\",options={}}\n--%%u={select=\"p1_cha_delay\",text=\"p1_cha_delay\",onToggled=\"p1_cha_delay\",options={}}\n\n--%%u={label=\"p1_timeinfo\",text=\"p1_timeinfo\"}\n--%%u={{text=\"p1_time_n\",visible=true,switch=\"p1_time_n\",onReleased=\"p1_time_n\"},{text=\"p1_time_p\",visible=true,switch=\"p1_time_p\",onReleased=\"p1_time_p\"},{button=\"unused1\",text=\"\",onReleased=\"unused1\"}}\n--%%u={{text=\"p1_time_cha\",visible=true,switch=\"p1_time_cha\",onReleased=\"p1_time_cha\"},{button=\"p1_time_minsec\",text=\"p1_time_minsec\",onReleased=\"p1_time_minsec\"},{button=\"unused2\",text=\"\",onReleased=\"unused2\"}}\n---- basic sensor delay,delay on, delay off, delay cha, delay priority cha,\n\n\n--%%u={label=\"infoLine9\",text=\"\"}\n--%%u={label=\"s1\",text=\"\"}\n--%%u={label=\"s2\",text=\"\"}\n--%%u={label=\"s3\",text=\"\"}\n--%%u={label=\"s4\",text=\"\"}\n--%%u={label=\"s5\",text=\"\"}\n\n\n-----example button layout\n--u={button=\"ID3\",text=\"Foo3\",visible=true,onLongPressDown=\"foo3\",onReleased=\"foo1\"}\n\n\n\n\n\n\n----files to import\n--%%file=C:\\VSCODE\\fibemu\\1. Profil LightController/Profile_Light_Controller_Translation.lua,Translation;\n--%%file=C:\\VSCODE\\fibemu\\1. Profil LightController/Profile_Light_Controller_Eventlib.lua,Eventlib;\n\n\n\n\n\n\n\n\n\n\n----\n--%%debug=refresh:false\n\n-------Quickapp variables\n--%%var=language:\"en\" \n--%%var=roomID:\"\" \n--%%var=Setup:\"0\" \n--%%var=Scene1:\"100%\" \n--%%var=Scene2:\"Dim\" \n--%%var=Scene3:\"Movie\" \n--%%var=Scene4:\"Dinner\" \n--%%var=Scene5:\"Rename\" \n--%%var=Scene6:\"qvars\" \n\n\n--%%var=color1:\"#ff9933\"      ----Orange            #ff9933     --- works on white and black\n--%%var=color2:\"#99ff33\"      ----Green             #99ff33     --- works on white and black\n--%%var=color3:\"#990000\"      ----red               #990000     --- works on white and black \n--%%var=color4:\"#66ffff\"      ----turquoise         #66ffff     --- works on white and black\n\n\n\n\n\n\n\n\n--color1 =  \"#ff9933\"      ----Orange            #ff9933     --- works on white and black\n--color2 =  \"#99ff33\"      ----Green             #99ff33     --- works on white and black\n--color3 =  \"#990000\"      ----red               #990000     --- works on white and black\n--color4 =  \"#66ffff\"      ----turquoise         #66ffff     --- works on white and black\n--color5 =  \"#ffff33\"      ----yellow            #ffff33     --- works on white and black\n--color6 =  \"#ff6633\"      ----DarkOrange        #ff6633     --- works on white and black\n--color7 =  \"#0000cc\"      ----blue              #0000cc     --- works on white and black\n--color8 =  \"#ff66ff\"      ----Pink              #ff66ff     --- works on white and black\n--color9 =  \"#660066\"      ----purple            #660066     --- works on white and black\n--color10 = \"#000000\"      ----black             #000000     \n--color11 = \"#ffffff\"      ----white             #ffffff     \n\n\n\n-------------------------------------------------------------------------------------------------------------------------------\n-------------------------------------------------------------------------------------------------------------------------------\n-------------------------------------------------------------------------------------------------------------------------------\n--[[Start  off instuctions\n\nIt is a fast way to get Motion Lights up and going. Just upload it to the room and choose from the dropdown menus. \n\nThis controller support motion sensor and Profile handling of Lights.\n\nChoose the lights and sensor to use from the room the controller is in.\n(can also use the Qvar to the room you want to controll to have the controller in an other room)\nYou can also store 6 custom Scenes (rename the scenes in the Qvars scene1 and scene 2.... - standard 100% and Dim) \n\nTo save the scenes just hold down the Save 100% or Save Dim button for 2sec when the lights are set as you want them to be.\n\nScenes also support rgbw2 controller programs and colors :D \n\nTo setup motion for each profile (max 10 profiles supported) \nchoose from the dropdownlist below the table/chart.\n\nthen choose what should happen on Pir ON /OFF Events (basic timer)\n\nAlso possible to choose what should happen ON/OFF delay event (Delay ON/OFF Timers)\n(example 2min after pir ON event that set lights to 20%, set the light 100%(wakeup lights))\n\nThen you can also choose what should happen when the profile change to example home/night etc.. Or even a delay after the change. \nThe priority sec is if you have alot of controllers u can set 0sec delay on the controller that should act first. Then set 1-2sec more on the next. \nThis is because you want the bedroom to act first when going to bed and first when you wake up for example :) \n\nand in the end you can change times for each profile by the + - change and sec/min/10xmin buttons. \n\n\n\n\nLabels can be changed colors with the Qvars color1,color2.. \n(might add support for theme colors)\n\n\nIt also support Language:\nen  -  English\nno  -  Norwegian\nde  -  German  (thanks stycx - https://forum.fibaro.com/profile/57588-stycx/)\npl  -  Polish  (thanks raffsa - https://forum.fibaro.com/profile/35572-raffsa/)\nfr  -  French  (thanks Tony270570 - https://forum.fibaro.com/profile/2410-tony270570/)\n\n\nIf you could help make support for other languages just hit me up on the forum: \nhttps://forum.fibaro.com/profile/50638-brors94/\nOr in this thread:\nhttps://forum.fibaro.com/topic/78508-easy-light-controller/\n\nAlso post in the topic above if you have anu suggestions or wishes :D\n\nSpecial Thanks to @jgab https://forum.fibaro.com/profile/2168-jgab/ \nNothing could have been done without his Eventlib and guides on the forum!!\n\n\n\n\nChangelog:\n\n5.1.25 \nFirst Release \n\n8.1.25\nbug fix with disable/enable motion sensor\nBetter Error handling if motion sensors or light isnt in the room \n\n15.1.25\nBug fix with Colorprograms and energy device showing in the select list on rgbw firmware 5.1\n\n16.1.25\nyesterday bug fix made a new bug :D \n(Scenes did only respond on color devices now)\nadded button labels to light up on last active scene\n\n28.2.26\nRefactor and stability update\n- Added disabled-device guard in onInit\n- Fixed profile setting storage to use real profile IDs\n- Fixed turnon/turnoff UI id handling\n- Added safe defaults for profile timers/actions\n- Changed infoLine separator size from 50px to 6px\n- Moved infoLine separator size into local config table\n- Added nil-safe scene saves and deterministic profile dropdown order\n- Fixed invalid empty-table check and removed legacy p1_on.scene field\n- Refactored scene save/set execution into shared helper functions for scene1-scene6\n- Fixed motion event normalization for custom sensors (safe/detected + 0/1 + true/false)\n- Fixed basic OFF timer reset-loop on repeated safe updates from polled sensors\n\n7.3.26\nPerformance and resilience update\n- Changed scene snapshots to store values by light device ID with legacy fallback for older snapshots\n- Added safe API and hub wrappers for startup scans, scene actions, and light commands\n- Added stale light selection cleanup during startup\n- Reduced repeated active profile API reads by caching the current profile ID\n- Fixed profile-change timer stacking and converted pending timer handles to locals\n- Replaced RGB action JSON string building with structured payload creation\n- Simplified the light summary label to show only room details and available lights\n- Simplified the motion sensor summary label to show only room details and available sensors\n- Shortened scene save/info labels to Name, Value, Color, and Program\n- Normalized label text to single line spacing\n- Reduced scene activation latency by trimming UI button updates and lowering RGBW program delay\n- Reduced scene overhead with one shared RGBW program timer, parsed color component storage, and direct turnOn/turnOff calls\n- Added a save_lights button so light multiselect changes are applied only when explicitly saved\n- Added one-second save_lights button feedback and refreshed the QA with unicode icons on key labels and buttons\n- Guarded unicode UI text updates and restored plain metadata labels so scene startup is not blocked by icon rendering issues\n- Fixed scene snapshot color fallback so non-color lights use plain values instead of invalid RGB calls\n- Added titled section headers and spacer descriptions to make the QA setup flow easier to scan\n- Reduced startup device reads, cached motion sensor states for PIR-off checks, localized leaked state variables, and wrapped startup event seed reads with safe error handling\n- Restored saved timer UI state on startup, centralized action dispatch logic, and removed duplicate setup locals and leftover debug code\n- Updated light and motion dropdown labels to use zero-padded ID and name formatting for easier scanning\n- Changed startup profile defaults so all profiles begin with turnOn, turnOff, and follow_pir baseline actions without requiring saved scenes\n- Expanded trigger sensor discovery to include door/window/contact/binary sensors by type, base type, and interface hints\n- Added explicit scene button callback methods so scene controls render reliably on startup\n- Changed the default basic PIR timer from 300 seconds to 0 seconds for new and missing profile entries\n- Moved room, light, and motion summary icons to the end of each line for cleaner label layout\n- Removed legacy Heatit/Fibaro Dimmer S2 trigger support and the related startup event reads\n- Merged startup motion and light discovery into one room device scan and removed redundant startup button text updates\n- Moved scene info Name and Value icons to the end of each line while keeping the save header icons at the start\n- Replaced startup profile loading with cached profile metadata and deferred `/profiles` refresh when cache is missing\n- Added forced profile metadata reload when the Setup reset qvar is used\n- Merged duplicated default reset logic into one shared helper, localized more internal helpers, and table-driven the scene/action button setup\n- Removed redundant startup button text writes and stale unused legacy UI label references after the scene/button refactor\n\n\n\n  \n]]  ----end off instuctions\n-------------------------------------------------------------------------------------------------------------------------------\n-------------------------------------------------------------------------------------------------------------------------------\n-------------------------------------------------------------------------------------------------------------------------------\n\n\n\n\n\n-----starttime measure\n  local starttime = os.clock()\n  print(\"starttime: \",starttime)\n  local Event = Event_std\n  local Fontsize = 2\n  local config = {\n      quickAppUuid = \"JBS30\",\n      version = \"v1.0.0\",\n      qa_type = \"30.Profile Light Controller\",\n      revision_date = \"30/04/26 16:22:28\",\n    ui = {\n      buttonFeedbackMs = 1000,\n      deferredActionUiUpdateDelayMs = 400,\n      infoLine = {\n        descriptionFontSize = 2,\n        titleFontSize = 4,\n        widthPx = 400,\n        sizePx = 6,\n      },\n      icons = {\n        color = \"🎨\",\n        confirm = \"✅\",\n        cycle = \"🔁\",\n        decrease = \"➖\",\n        disable = \"⛔\",\n        enable = \"✅\",\n        identifier = \"#\",\n        increase = \"➕\",\n        light = \"💡\",\n        motion = \"🚶\",\n        profile = \"👤\",\n        program = \"🌈\",\n        room = \"⌂\",\n        save = \"💾\",\n        scene = \"▶\",\n        timer = \"⏱\",\n        turnOff = \"🌙\",\n        turnOn = \"💡\",\n        value = \"◷\",\n      },\n    },\n    scene = {\n      -- RGBW program start needs a short delay after brightness set, but 1000 ms felt too slow in use.\n      colorProgramDelayMs = 50,\n    },\n  }\n  local action_dispatch_measurement_enabled = true  -- Set false to disable scene/turnOn/turnOff timing logs.\n-------------------------------------------------------------------------------------------------------------------------------\n----jgab eventlib \n  Event.id='start'\n  Event{type='QAstart'}\n  function Event:handler(event)\n  Event:attachRefreshstate()\nend\n -------------------------------------------------------------------------------------------------------------------------------\n ----jgab storage function\nfunction QuickApp:setupStorage()\n   local storage,qa = {},self\n   function storage:__index(key) return qa:internalStorageGet(key) end\n   function storage:__newindex(key,val)\n      if val == nil then qa:internalStorageRemove(key)\n      else qa:internalStorageSet(key,val) end\n   end\n   return setmetatable({},storage) \nend\n\nlocal dispatch_scene_save_callback\nlocal dispatch_scene_activate_callback\n\nfor scene_number = 1, 6 do\n  local current_scene_number = scene_number\n  local scene_save_control_name = \"scene\"..current_scene_number..\"_save\"\n  local scene_set_control_name = \"scene\"..current_scene_number..\"_set\"\n  local scene_set2_control_name = \"scene\"..current_scene_number..\"_set2\"\n\n  QuickApp[scene_save_control_name] = function(self, args)\n    if dispatch_scene_save_callback ~= nil then\n      return dispatch_scene_save_callback(self, current_scene_number, scene_save_control_name, args)\n    end\n  end\n\n  QuickApp[scene_set_control_name] = function(self, args)\n    if dispatch_scene_activate_callback ~= nil then\n      return dispatch_scene_activate_callback(self, current_scene_number, scene_set_control_name, args)\n    end\n  end\n\n  QuickApp[scene_set2_control_name] = function(self, args)\n    if dispatch_scene_activate_callback ~= nil then\n      return dispatch_scene_activate_callback(self, current_scene_number, scene_set2_control_name, args)\n    end\n  end\nend\n\nfibaro.debugFlags.post = false\n--------------------------------------------------------------------------------------------------------------------------------\n--------------------------------------------------------------------------------------------------------------------------------\n--Function ONinit                                     ]]      --[[     tonumber(\n--------------------------------------------------------------------------------------------------------------------------------\n--------------------------------------------------------------------------------------------------------------------------------\nfunction QuickApp:onInit()\n  local qa = self\n  local profil_id_active\n\n  local function safe_api_get(api_path, operation_description)\n    local success, response = pcall(api.get, api_path)\n    if not success then\n      self:error(operation_description..\": \"..tostring(response))\n      return nil\n    end\n    if response == nil then\n      self:warning(operation_description..\" returned nil for \"..api_path)\n    end\n    return response\n  end\n\n  local function safe_api_post(api_path, payload, operation_description)\n    local success, response = pcall(api.post, api_path, payload)\n    if not success then\n      self:error(operation_description..\": \"..tostring(response))\n      return nil\n    end\n    return response\n  end\n\n  local function safe_hub_get_value(device_id, property_name, operation_description)\n    local success, property_value = pcall(hub.getValue, device_id, property_name)\n    if not success then\n      self:error(operation_description..\" for device \"..tostring(device_id)..\" property \"..property_name..\": \"..tostring(property_value))\n      return nil\n    end\n    return property_value\n  end\n\n  local function safe_hub_call(device_id, action_name, ...)\n    local success, call_result = pcall(hub.call, device_id, action_name, ...)\n    if not success then\n      self:error(\"Device action failed for device \"..tostring(device_id)..\" action \"..action_name..\": \"..tostring(call_result))\n      return nil\n    end\n    return call_result\n  end\n\n  local quick_app_device = safe_api_get(\"/devices/\"..self.id, \"Unable to read QA device state\")\n  if quick_app_device ~= nil and quick_app_device.enabled == false then\n    self:debug(self.name,self.id,\"Device is disabled\")\n    return\n  end\n  local room_id = tonumber(self:getVariable(\"roomID\"))\n  local quickapp_id = self.id\n  local self_room_id\n  if room_id == nil then\n    local room_lookup_success, detected_room_id = pcall(hub.getRoomID, quickapp_id)\n    if not room_lookup_success then\n      self:error(\"Unable to detect room ID for QA \"..tostring(quickapp_id)..\": \"..tostring(detected_room_id))\n      return\n    end\n    self_room_id = detected_room_id\n  else \n    self_room_id = room_id\n  end\n  local room_name_success, room_name_result = pcall(hub.getRoomName, self_room_id)\n  local self_room_name = room_name_success and room_name_result or \"Unknown room\"\n  self:debug(\"DeviceId:\",self.id, \"   \" ,\"Name:\", self.name)\n  self:debug(\"Room:\",self_room_id, \"   \" ,\"Room Name:\", self_room_name)\n  self:updateProperty(\"log\", \"QA Started\")\n  self:updateProperty(\"deviceRole\", \"Other\")\n  self:updateProperty(\"categories\",{\"lights\"})\n  local current_quickapp_uuid = tostring(((quick_app_device or {}).properties or {}).quickAppUuid or \"\")\n  if current_quickapp_uuid ~= tostring(config.quickAppUuid or \"\") then\n    self:updateProperty(\"quickAppUuid\", config.quickAppUuid)\n    api.put(\"/devices/\" .. self.id, {properties = {quickAppUuid = config.quickAppUuid}}) -- Temporary: remove after first startup on existing QA.\n  end\n  self:updateProperty(\"useUiView\",false)\n  self:updateProperty(\"hasUIView\",false)\n  self.store = self:setupStorage()\n  --__TAG = \"QA_Room_Controller\"..\"_\"..tostring(quickapp_id)\n  ------------------description off QA\n  local function userDescription()\n  local line1 = \"Profile Light controller\"\n  local line2 = \"Made by Joachim Brørs Sommerfeld, Norway\"\n  local line3 = \"joachim.brors.sommerfeld@gmail.com\\nI am not a programer by craft/work, it is only a hobby so the code isnt perfect :D \"\n  local line4 = \"Use at own risk! ^^\\n\"\n  local line5 = \"This quickapp also uses the Eventlib made by:\"\n  local line6 = \"eventLib©️jan@gabrielsson.com\"\n  local line7 = \"And wouldnt work without it! Thanks!\"\n  self:updateProperty(\"userDescription\",\"\"..line1..\" \\n\"..line2..\"\\n\"..line3..\"\\n\"..line4..\"\\n\"..line5..\"\\n\"..line6..\"\\n\"..line7..\"\") \nend\n  userDescription()\n----------------------------------------------------------------\n----------------------------------------------------------------\n-----just to fixs labels/buttons not showing\nlocal labels = {\n\"turnoff\",\n\"turnon\",\n\"scene1_set\",\n\"scene2_set\",\n\"scene3_set\",\n\"scene4_set\",\n\"scene5_set\",\n\"scene6_set\",\n\"scene1_set2\",\n\"scene2_set2\",\n\"scene3_set2\",\n\"scene4_set2\", \n\"scene5_set2\",\n\"scene6_set2\",\n\"scene1_save\",\n\"scene2_save\",\n\"scene3_save\",\n\"scene4_save\",\n\"scene5_save\",\n\"scene6_save\",\n\"save_lights\",\n\"select_light_setup\",\n\"select_profile_setup\",\n\"select_motion_setup\",\n\"p1_time_minsec\",\n\"p1_time_p\",\n\"p1_time_n\",\n\"p1_time_cha\",\n} \nfor _,l in pairs(labels) do self:updateView(l,\"visible\",true) end\n----------------------------------------------------------------\nlocal labels2 = {\n\"unused1\",\n\"unused2\",\n} \nfor _,l in pairs(labels2) do self:updateView(l,\"visible\",false) end\n----------------------------------------------------------------\n----------------------------------------------------------------\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\nlocal profil_name = {}\nlocal profil_id = {}\nlocal should_refresh_profile_metadata_after_startup = false\nlocal should_force_profile_metadata_refresh_after_setup_reset = false\nlocal refresh_profile_dropdown_options\nlocal refresh_profile_metadata_from_api\nlocal schedule_profile_metadata_refresh\nlocal schedule_profile_cache_sync\nlocal profile_metadata_refresh_is_scheduled = false\nlocal profile_cache_sync_is_scheduled = false\n------------------- profile specs------------------- \n--self.store.profil_name = {}\n--self.store.profil_id = {}\nlocal function clear_table_entries(table_to_clear)\n  for table_key in pairs(table_to_clear or {}) do\n    table_to_clear[table_key] = nil\n  end\nend\n\nlocal function get_profile_display_name(profile_id_value)\n  local numeric_profile_id = tonumber(profile_id_value)\n  if numeric_profile_id ~= nil and tostring(profil_name[numeric_profile_id] or \"\") ~= \"\" then\n    return tostring(profil_name[numeric_profile_id])\n  end\n  if numeric_profile_id ~= nil then\n    return \"Profile \"..tostring(numeric_profile_id)\n  end\n  return \"Profile\"\nend\n\nlocal function get_sorted_profile_id_list()\n  local sorted_profile_id_list = {}\n  for _,profile_id_value in pairs(profil_id or {}) do\n    profile_id_value = tonumber(profile_id_value)\n    if profile_id_value ~= nil then\n      table.insert(sorted_profile_id_list, profile_id_value)\n    end\n  end\n  table.sort(sorted_profile_id_list)\n  return sorted_profile_id_list\nend\n\nlocal function rebuild_profile_metadata(profile_name_lookup, profile_id_list)\n  clear_table_entries(profil_name)\n  clear_table_entries(profil_id)\n\n  for _,profile_id_value in ipairs(profile_id_list or {}) do\n    local numeric_profile_id = tonumber(profile_id_value)\n    if numeric_profile_id ~= nil then\n      profil_id[numeric_profile_id] = numeric_profile_id\n      profil_name[numeric_profile_id] = tostring(\n        (profile_name_lookup or {})[numeric_profile_id]\n        or (profile_name_lookup or {})[tostring(numeric_profile_id)]\n        or (\"Profile \"..tostring(numeric_profile_id))\n      )\n    end\n  end\n\n  for profile_id_key,profile_name_value in pairs(profile_name_lookup or {}) do\n    local numeric_profile_id = tonumber(profile_id_key)\n    if numeric_profile_id ~= nil then\n      profil_id[numeric_profile_id] = numeric_profile_id\n      if tostring(profile_name_value or \"\") ~= \"\" then\n        profil_name[numeric_profile_id] = tostring(profile_name_value)\n      elseif profil_name[numeric_profile_id] == nil then\n        profil_name[numeric_profile_id] = \"Profile \"..tostring(numeric_profile_id)\n      end\n    end\n  end\nend\n\nlocal function persist_profile_metadata_cache()\n  local cached_profile_name_by_id = {}\n  local cached_profile_id_list = get_sorted_profile_id_list()\n\n  for _,profile_id_value in ipairs(cached_profile_id_list) do\n    cached_profile_name_by_id[tostring(profile_id_value)] = get_profile_display_name(profile_id_value)\n  end\n\n  self.store.profile_name_by_id = cached_profile_name_by_id\n  self.store.profile_id_list = cached_profile_id_list\n\n  if tonumber(profil_id_active) ~= nil then\n    self.store.profile_active_cached = tonumber(profil_id_active)\n  end\nend\n\nlocal function load_profile_metadata_from_store_cache()\n  local cached_profile_name_by_id = self.store.profile_name_by_id or {}\n  local cached_profile_id_list = self.store.profile_id_list or {}\n\n  if next(cached_profile_name_by_id) == nil and next(cached_profile_id_list) == nil then\n    return false\n  end\n\n  rebuild_profile_metadata(cached_profile_name_by_id, cached_profile_id_list)\n  return next(profil_id) ~= nil\nend\n\nlocal function derive_profile_metadata_from_existing_store()\n  local derived_profile_id_lookup = {}\n  local derived_profile_id_list = {}\n  local derived_profile_name_lookup = {}\n\n  local function append_derived_profile_id(candidate_profile_id)\n    local numeric_profile_id = tonumber(candidate_profile_id)\n    if numeric_profile_id == nil or derived_profile_id_lookup[numeric_profile_id] == true then\n      return\n    end\n\n    derived_profile_id_lookup[numeric_profile_id] = true\n    table.insert(derived_profile_id_list, numeric_profile_id)\n    derived_profile_name_lookup[numeric_profile_id] = \"Profile \"..tostring(numeric_profile_id)\n  end\n\n  append_derived_profile_id(self.store.profile_selected_trigger)\n  append_derived_profile_id(self.store.profile_active_cached)\n\n  local stored_profile_tables = {\n    self.store.p1_on,\n    self.store.p1_on_delay,\n    self.store.p1_off,\n    self.store.p1_off_delay,\n    self.store.p1_cha,\n    self.store.p1_cha_delay,\n    self.store.p1_basic_time,\n    self.store.p1_on_delay_time,\n    self.store.p1_off_delay_time,\n    self.store.p1_cha_delay_time,\n    self.store.p1_priority_time,\n  }\n\n  for _,stored_profile_table in ipairs(stored_profile_tables) do\n    for candidate_profile_id in pairs(stored_profile_table or {}) do\n      append_derived_profile_id(candidate_profile_id)\n    end\n  end\n\n  if #derived_profile_id_list == 0 then\n    return false\n  end\n\n  table.sort(derived_profile_id_list)\n  rebuild_profile_metadata(derived_profile_name_lookup, derived_profile_id_list)\n  return true\nend\n\nprofil_id_active = tonumber(self.store.profile_active_cached) or tonumber(self.store.profile_selected_trigger) or profil_id_active\n\nif load_profile_metadata_from_store_cache() ~= true then\n  derive_profile_metadata_from_existing_store()\n  should_refresh_profile_metadata_after_startup = true\nend\n\nlocal function get_first_profile_id()\n  local first_id = nil\n  for _,pid in pairs(profil_id or {}) do\n    pid = tonumber(pid)\n    if pid ~= nil and (first_id == nil or pid < first_id) then\n      first_id = pid\n    end\n  end\n  return first_id\nend\n\nlocal function get_active_profile_id()\n  if tonumber(profil_id_active) ~= nil then\n    return tonumber(profil_id_active)\n  end\n\n  if tonumber(self.store.profile_active_cached) ~= nil then\n    profil_id_active = tonumber(self.store.profile_active_cached)\n    return profil_id_active\n  end\n\n  return tonumber(self.store.profile_selected_trigger) or get_first_profile_id()\nend\n\nlocal default_profile_startup_settings\n\nlocal function ensure_profile_defaults()\n  self.store.p1_on = self.store.p1_on or {}\n  self.store.p1_on_delay = self.store.p1_on_delay or {}\n  self.store.p1_off = self.store.p1_off or {}\n  self.store.p1_off_delay = self.store.p1_off_delay or {}\n  self.store.p1_cha = self.store.p1_cha or {}\n  self.store.p1_cha_delay = self.store.p1_cha_delay or {}\n  self.store.p1_basic_time = self.store.p1_basic_time or {}\n  self.store.p1_on_delay_time = self.store.p1_on_delay_time or {}\n  self.store.p1_off_delay_time = self.store.p1_off_delay_time or {}\n  self.store.p1_cha_delay_time = self.store.p1_cha_delay_time or {}\n  self.store.p1_priority_time = self.store.p1_priority_time or {}\n\n  for _,pid in pairs(profil_id or {}) do\n    pid = tonumber(pid)\n    if pid ~= nil then\n      if self.store.p1_on[pid] == nil then self.store.p1_on[pid] = default_profile_startup_settings.p1_on end\n      if self.store.p1_on_delay[pid] == nil then self.store.p1_on_delay[pid] = default_profile_startup_settings.p1_on_delay end\n      if self.store.p1_off[pid] == nil then self.store.p1_off[pid] = default_profile_startup_settings.p1_off end\n      if self.store.p1_off_delay[pid] == nil then self.store.p1_off_delay[pid] = default_profile_startup_settings.p1_off_delay end\n      if self.store.p1_cha[pid] == nil then self.store.p1_cha[pid] = default_profile_startup_settings.p1_cha end\n      if self.store.p1_cha_delay[pid] == nil then self.store.p1_cha_delay[pid] = default_profile_startup_settings.p1_cha_delay end\n      if self.store.p1_basic_time[pid] == nil then self.store.p1_basic_time[pid] = default_profile_startup_settings.p1_basic_time end\n      if self.store.p1_on_delay_time[pid] == nil then self.store.p1_on_delay_time[pid] = default_profile_startup_settings.p1_on_delay_time end\n      if self.store.p1_off_delay_time[pid] == nil then self.store.p1_off_delay_time[pid] = default_profile_startup_settings.p1_off_delay_time end\n      if self.store.p1_cha_delay_time[pid] == nil then self.store.p1_cha_delay_time[pid] = default_profile_startup_settings.p1_cha_delay_time end\n      if self.store.p1_priority_time[pid] == nil then self.store.p1_priority_time[pid] = default_profile_startup_settings.p1_priority_time end\n    end\n  end\n\n  local valid_profile_ids = {}\n  for _,pid in pairs(profil_id or {}) do\n    pid = tonumber(pid)\n    if pid ~= nil then valid_profile_ids[pid] = true end\n  end\n\n  local stored_profile_id = tonumber(self.store.profile_selected_trigger)\n  if stored_profile_id ~= nil and not valid_profile_ids[stored_profile_id] then\n    stored_profile_id = nil\n  end\n\n  local default_profile_id = stored_profile_id or tonumber(profil_id_active) or get_first_profile_id()\n  if default_profile_id ~= nil then\n    self.store.profile_selected_trigger = default_profile_id\n  end\nend\n\nlocal function migrate_legacy_profile_priority_defaults()\n  if self.store.p1_priority_time_default_migrated_to_10s ~= nil then\n    return\n  end\n\n  local found_profile_configuration = false\n  for _,pid in pairs(profil_id or {}) do\n    pid = tonumber(pid)\n    if pid ~= nil then\n      found_profile_configuration = true\n      if tonumber(self.store.p1_priority_time[pid]) == 0 then\n        self.store.p1_priority_time[pid] = 10\n      end\n    end\n  end\n\n  if found_profile_configuration == true then\n    self.store.p1_priority_time_default_migrated_to_10s = true\n  end\nend\n  --print(\"profil_name\",json.encode(self.store.profil_name))\n  --print(\"profil_id\",json.encode(self.store.profil_id))\n\n\n\n\n\n----------------------------------------------------------------\n----------------------------------------------------------------\n--------- first time QA runs\ndefault_profile_startup_settings = {\n  p1_on = \"turnOn\",\n  p1_on_delay = \"no_action\",\n  p1_off = \"turnOff\",\n  p1_off_delay = \"no_action\",\n  p1_cha = \"follow_pir\",\n  p1_cha_delay = \"no_action\",\n  p1_basic_time = 0,\n  p1_on_delay_time = 300,\n  p1_off_delay_time = 300,\n  p1_cha_delay_time = 300,\n  p1_priority_time = 10,\n}\n\nlocal function get_default_profile_target_id_list()\n  local default_profile_target_id_list = get_sorted_profile_id_list()\n  if #default_profile_target_id_list > 0 then\n    return default_profile_target_id_list\n  end\n\n  default_profile_target_id_list = {}\n  for default_profile_index = 1, 10 do\n    table.insert(default_profile_target_id_list, default_profile_index)\n  end\n\n  return default_profile_target_id_list\nend\n\nlocal function build_default_profile_setting_list(default_value)\n  local default_profile_setting_list = {}\n  for _,profile_id_value in ipairs(get_default_profile_target_id_list()) do\n    profile_id_value = tonumber(profile_id_value) or profile_id_value\n    default_profile_setting_list[profile_id_value] = default_value\n  end\n  return default_profile_setting_list\nend\n\nlocal function build_default_profile_time_list(default_time_value)\n  return build_default_profile_setting_list(default_time_value)\nend\n\nlocal function reset_standard_settings(reset_status_text)\n  self.store.lightid_trigger = {}\n  self.store.lightid_trigger_select = {}\n  self.store.current_value = \"\"\n  self.store.current_color = \"\"\n  self.store.current_color_program = \"\"\n\n  for scene_number = 1, 6 do\n    self.store[\"scene\"..scene_number..\"_value\"] = {}\n    self.store[\"scene\"..scene_number..\"_color\"] = {}\n    self.store[\"scene\"..scene_number..\"_color_string\"] = {}\n    self.store[\"scene\"..scene_number..\"_color_program\"] = {}\n  end\n\n  self.store.delay_timer_p1 = 300\n  self.store.sensor_timer_p1 = 300\n  self.store.sec_min_sensor = \"min\"\n  self.store.enable_status = \"on\"\n\n  self.store.p1_on_args = {}\n  self.store.p1_on = build_default_profile_setting_list(default_profile_startup_settings.p1_on)\n  self.store.p1_on_delay = build_default_profile_setting_list(default_profile_startup_settings.p1_on_delay)\n  self.store.p1_off = build_default_profile_setting_list(default_profile_startup_settings.p1_off)\n  self.store.p1_off_delay = build_default_profile_setting_list(default_profile_startup_settings.p1_off_delay)\n  self.store.p1_cha = build_default_profile_setting_list(default_profile_startup_settings.p1_cha)\n  self.store.p1_cha_delay = build_default_profile_setting_list(default_profile_startup_settings.p1_cha_delay)\n  self.store.p1_basic_time = build_default_profile_time_list(default_profile_startup_settings.p1_basic_time)\n  self.store.p1_on_delay_time = build_default_profile_time_list(default_profile_startup_settings.p1_on_delay_time)\n  self.store.p1_off_delay_time = build_default_profile_time_list(default_profile_startup_settings.p1_off_delay_time)\n  self.store.p1_cha_delay_time = build_default_profile_time_list(default_profile_startup_settings.p1_cha_delay_time)\n  self.store.p1_priority_time = build_default_profile_time_list(default_profile_startup_settings.p1_priority_time)\n  self.store.p1_time_cha = 1\n  self.store.time_cha = 1\n  self.store.profile_selected_trigger = profil_id_active\n  self.store.motionsensorid_trigger = nil\n  self.store.motionsensorid_trigger_select = {}\n  self.store.profile_name_by_id = nil\n  self.store.profile_id_list = nil\n  self.store.profile_active_cached = tonumber(profil_id_active) or nil\n  self.store.current_scene = nil\n  self.store.last_active_button_names = nil\n  self.store.first_time = reset_status_text\n  print(self.store.first_time)\nend\n\nif self.store.first_time == nil then   ----       ~=\n  reset_standard_settings(\"First time Installation is Done\")\nend  -----First time Installation is Done\"\n\nlocal function new_setup()\n  reset_standard_settings(\"New Setup Done\")\nend  -----First time Installation is Done\"\n\n\n\nlocal setup = self:getVariable(\"Setup\") or \"0\"\nif setup ~= \"0\" then\n  self:setVariable(\"Setup\",\"0\")\n  new_setup()\n  should_force_profile_metadata_refresh_after_setup_reset = true\nend\nensure_profile_defaults()\nmigrate_legacy_profile_priority_defaults()\nif next(profil_id) == nil and derive_profile_metadata_from_existing_store() == true then\n  ensure_profile_defaults()\n  migrate_legacy_profile_priority_defaults()\nend\n\nlocal function normalize_time_selection_mode(candidate_time_selection_mode)\n  local normalized_time_selection_mode = tonumber(candidate_time_selection_mode)\n  if normalized_time_selection_mode == nil then\n    return 1\n  end\n\n  normalized_time_selection_mode = math.floor(normalized_time_selection_mode)\n  if normalized_time_selection_mode < 1 or normalized_time_selection_mode > 5 then\n    return 1\n  end\n\n  return normalized_time_selection_mode\nend\n\nlocal function normalize_time_unit_mode(candidate_time_unit_mode)\n  local normalized_time_unit_mode = tostring(candidate_time_unit_mode or \"sec\")\n  if normalized_time_unit_mode == \"sec\" or normalized_time_unit_mode == \"min\" or normalized_time_unit_mode == \"minx10\" then\n    return normalized_time_unit_mode\n  end\n  return \"sec\"\nend\n\nself.store.time_cha = normalize_time_selection_mode(self.store.time_cha or self.store.p1_time_cha)\nself.store.p1_time_cha = self.store.time_cha\nself.store.sec_min_sensor = normalize_time_unit_mode(self.store.sec_min_sensor)\n\n----------------------------------------------------------------\n----------------------------------------------------------------\n----------------------------------------------------------------\n\nlocal color_transit_time = config.scene.colorProgramDelayMs\nlocal p1_on = self.store.p1_on\nlocal p1_on_delay = self.store.p1_on_delay\nlocal p1_off = self.store.p1_off\nlocal p1_off_delay = self.store.p1_off_delay\nlocal p1_cha = self.store.p1_cha\nlocal p1_cha_delay = self.store.p1_cha_delay\nlocal p1_basic_time = self.store.p1_basic_time\nlocal p1_on_delay_time = self.store.p1_on_delay_time\nlocal p1_off_delay_time = self.store.p1_off_delay_time\nlocal p1_cha_delay_time = self.store.p1_cha_delay_time\nlocal p1_priority_time = self.store.p1_priority_time\nlocal refresh_all_scene_info_views\nlocal run_scene_snapshot_by_number\nlocal update_selecteditem\nlocal profile_info\nlocal p1_on_info\nlocal p1_off_info\nlocal p1_cha_info\nlocal p1_time_cha\nlocal p1_timeinfo\nlocal info_pir_enable\nlocal enable_status_fun\nlocal turnon\nlocal turnoff\nlocal cancel_pir_timers\nlocal cancel_profile_change_timers\nlocal funpirstatuson\nlocal funPirStatusOff\nlocal fibaro_pir_check_off\nlocal motionsensorid_off\nlocal check_pir_on_p1\nlocal check_pir_on_delay_p1\nlocal check_pir_off_p1\nlocal check_pir_off_delay_p1\nlocal check_profile_cha\nlocal check_profile_cha_delay\nlocal set_action_button_state\nlocal button_labels_false\n\n\n\n\n\n----------------------------------------------------------------\n----------------------------------------------------------------\n---------------------------------------------------------------\n  local update_select_profil = {}\n  --print(\"profil_id\",profil_id)\n  --print(\"profil_name\",profil_name)\n\nrefresh_profile_dropdown_options = function(should_persist_selected_profile)\n  if should_persist_selected_profile == nil then\n    should_persist_selected_profile = true\n  end\n\n  local sorted_profile_id_list = get_sorted_profile_id_list()\n  update_select_profil = {}\n\n  for profile_option_index,profile_id_value in ipairs(sorted_profile_id_list) do\n    update_select_profil[profile_option_index] = {\n      text = get_profile_display_name(profile_id_value),\n      type = \"option\",\n      value = tostring(profile_id_value),\n    }\n  end\n\n  self:updateView(\"select_profile_setup\", \"options\", update_select_profil)\n\n  local selected_profile_id = tonumber(self.store.profile_selected_trigger)\n  if selected_profile_id == nil or profil_id[selected_profile_id] == nil then\n    selected_profile_id = get_active_profile_id() or get_first_profile_id()\n    if should_persist_selected_profile == true and selected_profile_id ~= nil then\n      self.store.profile_selected_trigger = selected_profile_id\n    end\n  end\n\n  if selected_profile_id ~= nil then\n    self:updateView(\"select_profile_setup\", \"selectedItem\", tostring(selected_profile_id))\n  end\nend\n\nrefresh_profile_metadata_from_api = function(should_refresh_ui_after_load)\n  local profiles_response = safe_api_get(\"/profiles\", \"Unable to refresh profile metadata\")\n  if profiles_response == nil then\n    return false\n  end\n\n  local loaded_profile_name_lookup = {}\n  local loaded_profile_id_list = {}\n  for _,profile_data in pairs(profiles_response.profiles or {}) do\n    local numeric_profile_id = tonumber(profile_data.id)\n    if numeric_profile_id ~= nil then\n      table.insert(loaded_profile_id_list, numeric_profile_id)\n      loaded_profile_name_lookup[numeric_profile_id] = tostring(profile_data.name or (\"Profile \"..tostring(numeric_profile_id)))\n    end\n  end\n\n  if #loaded_profile_id_list == 0 then\n    self:warning(\"Profile metadata refresh returned no profiles\")\n    return false\n  end\n\n  table.sort(loaded_profile_id_list)\n  profil_id_active = tonumber(profiles_response.activeProfile) or tonumber(self.store.profile_active_cached) or profil_id_active\n  rebuild_profile_metadata(loaded_profile_name_lookup, loaded_profile_id_list)\n  persist_profile_metadata_cache()\n  ensure_profile_defaults()\n  migrate_legacy_profile_priority_defaults()\n\n  if should_refresh_ui_after_load == true then\n    refresh_profile_dropdown_options()\n    update_selecteditem()\n    profile_info()\n    p1_on_info()\n    p1_off_info()\n    p1_cha_info()\n    p1_timeinfo()\n  end\n\n  return true\nend\n\nschedule_profile_cache_sync = function()\n  if profile_cache_sync_is_scheduled == true then\n    return\n  end\n\n  profile_cache_sync_is_scheduled = true\n  hub.setTimeout(1, function()\n    profile_cache_sync_is_scheduled = false\n    persist_profile_metadata_cache()\n    refresh_profile_dropdown_options(true)\n  end)\nend\n\nschedule_profile_metadata_refresh = function()\n  if profile_metadata_refresh_is_scheduled == true then\n    return\n  end\n\n  profile_metadata_refresh_is_scheduled = true\n  hub.setTimeout(250, function()\n    profile_metadata_refresh_is_scheduled = false\n    refresh_profile_metadata_from_api(true)\n  end)\nend\n\nif should_force_profile_metadata_refresh_after_setup_reset == true then\n  should_refresh_profile_metadata_after_startup = refresh_profile_metadata_from_api(false) ~= true\nend\n\nrefresh_profile_dropdown_options()\n\n\n\n\n----------------------------------------------------------------\n----------------------------------------------------------------\n----------------------------------------------------------------\n----------------------------------------------------------------\n \n    local scene1 = self:getVariable(\"Scene1\") or \"Scene1\"\n    local scene2 = self:getVariable(\"Scene2\") or \"Scene2\"\n    local scene3 = self:getVariable(\"Scene3\") or \"Scene3\"\n    local scene4 = self:getVariable(\"Scene4\") or \"Scene4\"\n    local scene5 = self:getVariable(\"Scene5\") or \"Scene5\"\n    local scene6 = self:getVariable(\"Scene6\") or \"Scene6\"\n    local scene_name_by_number = {\n      scene1,\n      scene2,\n      scene3,\n      scene4,\n      scene5,\n      scene6,\n    }\n\n\n\n\n\n\n\n----------------------------------------------------------------\n----------------------------------------------------------------\n------label colors \nlocal color1 = self:getVariable(\"color1\") or \"Orange\"  --\"<font color=Orange>\"\ncolor1 = \"<font color=\"..color1..\">\"\nlocal color2 = self:getVariable(\"color2\") or \"green\"  --\"<font color=green>\"\ncolor2 = \"<font color=\"..color2..\">\"\nlocal color3 = self:getVariable(\"color3\") or \"red\"  --\"<font color=red>\"\ncolor3 = \"<font color=\"..color3..\">\"\nlocal color4 = self:getVariable(\"color4\") or \"turquoise\"  ----\"turquoise\"\n\n----------------------------------------------------------------\n----------------------------------------------------------------\n----------------\n    local enable_status = self.store.enable_status \n----------------\n    -- legacy save1..save6 keys removed; scene values are stored in scene1_value..scene6_value\n----------------\n    local fibaropir = 0\n----------------\n    local lightid_trigger \n    local lightid_trigger_select\n    if self.store.lightid_trigger ~= nil then\n    lightid_trigger = self.store.lightid_trigger \n    else\n    lightid_trigger = {}\n    end\n    if self.store.lightid_trigger_select ~= nil then\n    lightid_trigger_select = self.store.lightid_trigger_select \n    else\n    lightid_trigger_select = {}\n    end\n    local function clone_id_list(source_id_list)\n      local cloned_id_list = {}\n      for source_index,source_id_value in ipairs(source_id_list or {}) do\n        cloned_id_list[source_index] = source_id_value\n      end\n      return cloned_id_list\n    end\n    local pending_lightid_trigger_select = clone_id_list(lightid_trigger_select)\n\n\n\n\n\n----------------------------------------------------------------\n----------------------------------------------------------------\n----motions sensor update on startup\nlocal room_devices_for_startup_scan = safe_api_get(\n  \"/devices?roomID=\"..self_room_id..\"&enabled=true&visible=true\",\n  \"Unable to load room devices for startup scan\"\n) or {}\nlocal motion_ids = {}\nlocal motion_name = {}\nlocal motionsensorid = {}\nlocal motion_sensor_state_by_device_id = {}\nlocal refresh_motion_sensor_state_cache\n  local function sensor_device_has_interface(device_record, interface_name)\n    for _,device_interface_name in ipairs((device_record and device_record.interfaces) or {}) do\n      if tostring(device_interface_name) == tostring(interface_name) then\n        return true\n      end\n    end\n    return false\n  end\n\n  local function sensor_device_matches_type_hint(device_record, type_hints)\n    for _,candidate_value in ipairs({\n      tostring(device_record and device_record.type or \"\"),\n      tostring(device_record and device_record.baseType or \"\"),\n    }) do\n      local normalized_candidate_value = string.lower(candidate_value)\n      for _,type_hint in ipairs(type_hints or {}) do\n        if string.find(normalized_candidate_value, tostring(type_hint), 1, true) ~= nil then\n          return true\n        end\n      end\n    end\n    return false\n  end\n\n  local function is_supported_trigger_sensor(device_record)\n    if type(device_record) ~= \"table\" then\n      return false\n    end\n\n    if device_record.baseType == \"com.fibaro.FGMS001\" then\n      return true\n    end\n\n    if device_record.type == \"com.fibaro.binarySensor\"\n      or device_record.type == \"com.fibaro.doorSensor\"\n      or device_record.type == \"com.fibaro.presenceSensor\"\n      or device_record.type == \"com.fibaro.motionSensor\" then\n      return true\n    end\n\n    if sensor_device_has_interface(device_record, \"binarySensor\")\n      or sensor_device_has_interface(device_record, \"doorSensor\")\n      or sensor_device_has_interface(device_record, \"windowSensor\")\n      or sensor_device_has_interface(device_record, \"contactSensor\") then\n      return true\n    end\n\n    return sensor_device_matches_type_hint(device_record, {\n      \"binarysensor\",\n      \"doorsensor\",\n      \"windowsensor\",\n      \"contactsensor\",\n      \"motionsensor\",\n      \"presencesensor\",\n      \"fgdw\",\n      \"fgk\",\n      \"fgms\",\n    })\n  end\n\n  local function update_motion()\n    local rownumber = 1\n    for _,motion in ipairs(room_devices_for_startup_scan) do\n        if is_supported_trigger_sensor(motion) then\n          motion_ids[rownumber] = motion.id\n          motionsensorid[rownumber] = motion.id\n          motion_name[rownumber] = motion.name\n          rownumber = rownumber + 1\n        end  \n    end \n\n  end\nupdate_motion()\n\n----------------------------------------------------------------\n----------------------------------------------------------------\n----check id of the stored motionsensorid_trigger list is still in the room on the motionsensorid list else remove them \n\nlocal motionsensorid_trigger = {}\nlocal motionsensorid_trigger_select\nif self.store.motionsensorid_trigger ~= nil then\n\nmotionsensorid_trigger = self.store.motionsensorid_trigger \n--print(\"motionsensorid_trigger 1\",json.encode(motionsensorid_trigger))\nfor ind,val in pairs(motionsensorid_trigger)do\n  --print(\"motionsensorid_trigger val\" , val)\n  --print(\"motionsensorid_trigger ind\",ind)\n  --print(\"motionsensorid_trigger val\",val)\n  local var = false\n    --print (\"test2\")\n      for inde,valu in pairs(motionsensorid)do\n        --print(\"motionsensorid_trigger2 inde\",inde)\n        --print(\"motionsensorid_trigger2 valu\",valu)\n        if (tostring(valu) == tostring(val)) then\n          var = true\n        end\n      end--forloop motionsensorid\n      if var == false then \n        --print(ind,\"should delete\")\n        motionsensorid_trigger[ind] = nil\n      end\nend--forloop motionsensorid_trigger\n--print(\"motionsensorid_trigger 2\",json.encode(motionsensorid_trigger))\nelse\nmotionsensorid_trigger = {}\nend\n\n\n----------------------------------------------------------------\n  if self.store.motionsensorid_trigger_select ~= nil then\n  motionsensorid_trigger_select = self.store.motionsensorid_trigger_select \n  else\n  motionsensorid_trigger_select = {} \n  end\n\n  local function reconcile_selected_motion_sensors_with_room()\n    local valid_motion_sensor_lookup = {}\n    local selected_motion_sensor_id_list = {}\n    local selected_motion_sensor_lookup = {}\n\n    local function append_selected_motion_sensor_if_valid(candidate_motion_sensor_id)\n      if candidate_motion_sensor_id == nil then\n        return\n      end\n\n      local motion_sensor_id_string = tostring(candidate_motion_sensor_id)\n      if valid_motion_sensor_lookup[motion_sensor_id_string] ~= true then\n        self:warning(\"Removed unavailable motion sensor from stored selection: \"..motion_sensor_id_string)\n        return\n      end\n\n      if selected_motion_sensor_lookup[motion_sensor_id_string] == true then\n        return\n      end\n\n      table.insert(selected_motion_sensor_id_list, motion_sensor_id_string)\n      selected_motion_sensor_lookup[motion_sensor_id_string] = true\n    end\n\n    for _,motion_sensor_device_id in ipairs(motion_ids or {}) do\n      valid_motion_sensor_lookup[tostring(motion_sensor_device_id)] = true\n    end\n\n    for _,selected_motion_sensor_id in ipairs(motionsensorid_trigger_select or {}) do\n      append_selected_motion_sensor_if_valid(selected_motion_sensor_id)\n    end\n\n    for _,selected_motion_sensor_id in pairs(motionsensorid_trigger or {}) do\n      append_selected_motion_sensor_if_valid(selected_motion_sensor_id)\n    end\n\n    motionsensorid_trigger = {}\n    for _,selected_motion_sensor_id in ipairs(selected_motion_sensor_id_list) do\n      motionsensorid_trigger[selected_motion_sensor_id] = selected_motion_sensor_id\n    end\n\n    motionsensorid_trigger_select = selected_motion_sensor_id_list\n    self.store.motionsensorid_trigger = motionsensorid_trigger\n    self.store.motionsensorid_trigger_select = motionsensorid_trigger_select\n  end\n  reconcile_selected_motion_sensors_with_room()\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n----------------------------------------------------------------\n----------------------------------------------------------------\n----room and lights on startup\n    local light_ids = {}\n    local light_name = {}\n    local light_name_by_id = {}\n    local function device_has_interface(device_record, interface_name)\n      for _,device_interface_name in ipairs(device_record.interfaces or {}) do\n        if device_interface_name == interface_name then\n          return true\n        end\n      end\n      return false\n    end\n    local function update_light()\n      local rownumber = 1\n      for _,light in ipairs(room_devices_for_startup_scan) do\n        if device_has_interface(light, \"light\") and light.type ~= \"com.fibaro.FGRGBW442\" then\n          light_ids[rownumber] = light.id or \"\"\n          light_name[rownumber] = light.name or \"\"\n          light_name_by_id[tostring(light.id)] = light.name or \"\"\n          rownumber = rownumber + 1\n        end\n      end\n    end\n  \n  local function reconcile_selected_lights_with_room()\n    local valid_light_id_lookup = {}\n    local selected_light_id_order = {}\n    local selected_light_id_lookup = {}\n\n    local function append_selected_light_if_valid(candidate_light_id)\n      if candidate_light_id == nil then\n        return\n      end\n\n      local light_id_string = tostring(candidate_light_id)\n      if valid_light_id_lookup[light_id_string] ~= true then\n        self:warning(\"Removed unavailable light from stored selection: \"..light_id_string)\n        return\n      end\n\n      if selected_light_id_lookup[light_id_string] == true then\n        return\n      end\n\n      table.insert(selected_light_id_order, light_id_string)\n      selected_light_id_lookup[light_id_string] = true\n    end\n\n    for _,light_id in ipairs(light_ids or {}) do\n      valid_light_id_lookup[tostring(light_id)] = true\n    end\n\n    for _,selected_light_id in ipairs(lightid_trigger_select or {}) do\n      append_selected_light_if_valid(selected_light_id)\n    end\n\n    for _,selected_light_id in pairs(lightid_trigger or {}) do\n      append_selected_light_if_valid(selected_light_id)\n    end\n\n    lightid_trigger = {}\n    for _,selected_light_id in ipairs(selected_light_id_order) do\n      lightid_trigger[selected_light_id] = selected_light_id\n    end\n\n    lightid_trigger_select = selected_light_id_order\n    pending_lightid_trigger_select = clone_id_list(lightid_trigger_select)\n    self.store.lightid_trigger = lightid_trigger\n    self.store.lightid_trigger_select = lightid_trigger_select\n  end\n  update_light()\n  reconcile_selected_lights_with_room()\n\n----------------------------------------------------------------\n------Supported language check \n    local language = self:getVariable(\"language\") or \"en\"\n    if string.lower(language) == \"en\" then\n    print(\"English\")\n    elseif  string.lower(language) == \"no\"  then\n    print(\"Norwegian\")\n    elseif  string.lower(language) == \"de\"  then\n    print(\"German\")\n    elseif  string.lower(language) == \"pl\"  then\n    print(\"Polish\")\n    elseif  string.lower(language) == \"fr\"  then\n    print(\"French\")\n    else\n    language = \"en\"\n    print(\"Language not recognised, English is set\")\n    self:setVariable(\"language\", \"en\")\n    end\n    local translation = lang:translation(self:getVariable(\"language\")) \n\n----------------------------------------------------------------\n------------language setup variables\nlocal qa_ui_icons = config.ui.icons or {}\n\nlocal function build_icon_text(icon_symbol, plain_text)\n  local icon_text = tostring(icon_symbol or \"\")\n  local plain_caption_text = tostring(plain_text or \"\")\n  if icon_text == \"\" then\n    return plain_caption_text\n  end\n  if plain_caption_text == \"\" then\n    return icon_text\n  end\n  return icon_text..\" \"..plain_caption_text\nend\n\nlocal function build_trailing_icon_text(plain_text, icon_symbol)\n  local plain_caption_text = tostring(plain_text or \"\")\n  local icon_text = tostring(icon_symbol or \"\")\n  if icon_text == \"\" then\n    return plain_caption_text\n  end\n  if plain_caption_text == \"\" then\n    return icon_text\n  end\n  return plain_caption_text..\" \"..icon_text\nend\n\nlocal function format_dropdown_device_option_text(device_id, device_name)\n  local numeric_device_id = tonumber(device_id)\n  local formatted_device_id_text\n  if numeric_device_id ~= nil then\n    formatted_device_id_text = string.format(\"%04d\", numeric_device_id)\n  else\n    formatted_device_id_text = tostring(device_id or \"\")\n  end\n\n  return \"ID: \"..formatted_device_id_text..\" Name: \"..tostring(device_name or \"\")\nend\n\nlocal function try_update_view_text(view_name, text_value)\n  pcall(self.updateView, self, view_name, \"text\", text_value)\nend\n\nlocal save_selected_lights_button_idle_text = build_icon_text(qa_ui_icons.save, \"Save selected lights\")\nlocal save_selected_lights_button_active_text = build_icon_text(qa_ui_icons.confirm, \"Lights saved\")\nlocal ui_feedback_timer_by_control_name = {}\nlocal deferred_action_ui_update_timer\nlocal deferred_action_ui_update_token = 0\n\nlocal function cancel_pending_deferred_action_ui_update()\n  deferred_action_ui_update_token = deferred_action_ui_update_token + 1\n  if deferred_action_ui_update_timer ~= nil then\n    hub.clearTimeout(deferred_action_ui_update_timer)\n    deferred_action_ui_update_timer = nil\n  end\nend\n\nlocal function schedule_deferred_action_ui_update(ui_update)\n  if type(ui_update) ~= \"table\" then\n    return\n  end\n\n  deferred_action_ui_update_token = deferred_action_ui_update_token + 1\n  local scheduled_ui_update_token = deferred_action_ui_update_token\n\n  if deferred_action_ui_update_timer ~= nil then\n    hub.clearTimeout(deferred_action_ui_update_timer)\n    deferred_action_ui_update_timer = nil\n  end\n\n  deferred_action_ui_update_timer = hub.setTimeout(config.ui.deferredActionUiUpdateDelayMs or 75, function()\n    deferred_action_ui_update_timer = nil\n    if scheduled_ui_update_token ~= deferred_action_ui_update_token then\n      return\n    end\n\n    if ui_update.measurementStoreKey ~= nil and ui_update.measurementSummary ~= nil then\n      self.store[ui_update.measurementStoreKey] = ui_update.measurementSummary\n    end\n    if ui_update.debugText ~= nil then\n      self:debug(ui_update.debugText)\n    end\n    if ui_update.logText ~= nil then\n      self:updateProperty(\"log\", ui_update.logText)\n    end\n    if ui_update.activeButtonNames ~= nil and set_action_button_state ~= nil then\n      set_action_button_state(ui_update.activeButtonNames)\n    end\n    if ui_update.currentScene ~= nil then\n      self.store.current_scene = ui_update.currentScene\n    end\n  end)\nend\n\nlocal function pulse_ui_control_feedback(control_name, idle_control_text, active_control_text, active_duration_ms)\n  if ui_feedback_timer_by_control_name[control_name] ~= nil then\n    hub.clearTimeout(ui_feedback_timer_by_control_name[control_name])\n    ui_feedback_timer_by_control_name[control_name] = nil\n  end\n\n  if active_control_text ~= nil then\n    try_update_view_text(control_name, active_control_text)\n  end\n  pcall(self.updateView, self, control_name, \"value\", \"true\")\n\n  ui_feedback_timer_by_control_name[control_name] = hub.setTimeout(active_duration_ms or config.ui.buttonFeedbackMs or 1000, function()\n    ui_feedback_timer_by_control_name[control_name] = nil\n    if idle_control_text ~= nil then\n      try_update_view_text(control_name, idle_control_text)\n    end\n    pcall(self.updateView, self, control_name, \"value\", \"false\")\n  end)\nend\n\nlocal function build_runtime_button_text_by_control_name()\n  local runtime_button_text_by_control_name = {\n    disable = build_icon_text(qa_ui_icons.disable, translation[\"disable\"]),\n    enable = build_icon_text(qa_ui_icons.enable, translation[\"enable\"]),\n    p1_time_cha = build_icon_text(qa_ui_icons.cycle, translation[\"change\"]),\n    p1_time_n = qa_ui_icons.decrease or \"-\",\n    p1_time_p = qa_ui_icons.increase or \"+\",\n    save_lights = save_selected_lights_button_idle_text,\n    select_light_setup = build_icon_text(qa_ui_icons.light, \"Light List\"),\n    select_motion_setup = build_icon_text(qa_ui_icons.motion, \"Sensors\"),\n    select_profile_setup = build_icon_text(qa_ui_icons.profile, \"Profiles\"),\n    turnoff = build_icon_text(qa_ui_icons.turnOff, translation[\"turnOff\"]),\n    turnon = build_icon_text(qa_ui_icons.turnOn, translation[\"turnOn\"]),\n  }\n\n  for scene_number,scene_name in ipairs(scene_name_by_number) do\n    local scene_activate_button_text = build_icon_text(qa_ui_icons.scene, scene_name)\n    runtime_button_text_by_control_name[\"scene\"..scene_number..\"_save\"] = build_icon_text(qa_ui_icons.save, translation[\"Save\"]..\" \"..scene_name)\n    runtime_button_text_by_control_name[\"scene\"..scene_number..\"_set\"] = scene_activate_button_text\n    runtime_button_text_by_control_name[\"scene\"..scene_number..\"_set2\"] = scene_activate_button_text\n  end\n\n  return runtime_button_text_by_control_name\nend\n\nlocal function refresh_static_ui_button_texts()\n  local runtime_button_text_by_control_name = build_runtime_button_text_by_control_name()\n  for control_name,control_text in pairs(runtime_button_text_by_control_name) do\n    try_update_view_text(control_name, control_text)\n  end\nend\n\n\n\n\n\n\n\n\n----------------------------------------------------------------\n----------------------------------------------------------------\n----------------------------------------------------------------\n-----scnes dropdown list\n    local function build_action_dropdown_option_list(include_follow_pir_action)\n      local action_dropdown_option_list = {\n        {text = \"\"..translation[\"no_action\"]..\"\", type = \"option\", value = \"no_action\"},\n        {text = \"\"..translation[\"turnOn\"]..\"\", type = \"option\", value = \"turnOn\"},\n        {text = \"\"..translation[\"turnOff\"]..\"\", type = \"option\", value = \"turnOff\"},\n      }\n\n      if include_follow_pir_action == true then\n        table.insert(action_dropdown_option_list, {text = \"\"..translation[\"follow_pir\"]..\"\", type = \"option\", value = \"follow_pir\"})\n      end\n\n      for scene_number,scene_name in ipairs(scene_name_by_number) do\n        table.insert(action_dropdown_option_list, {\n          text = tostring(scene_name),\n          type = \"option\",\n          value = \"scene\"..scene_number,\n        })\n      end\n\n      return action_dropdown_option_list\n    end\n\n    local update_select_list = build_action_dropdown_option_list(false)\n    self:updateView(\"p1_on\", \"options\", update_select_list)\n    self:updateView(\"p1_on_delay\", \"options\", update_select_list)\n    self:updateView(\"p1_off\", \"options\", update_select_list)\n    self:updateView(\"p1_off_delay\", \"options\", update_select_list)\n    self:updateView(\"p1_cha_delay\", \"options\", update_select_list)\n    local update_select_list2 = build_action_dropdown_option_list(true)\n    self:updateView(\"p1_cha\", \"options\", update_select_list2)\n    \n\nlocal function get_selected_profile_id()\n  return tonumber(self.store.profile_selected_trigger) or get_active_profile_id() or get_first_profile_id()\nend\n----------------------------------------------------------------------------------------------------------\n-----profile dropdown list handler\nlocal profile_select_var = {}\nfunction QuickApp:select_profile_setup(args)\n  local selected_profile_value = args and args.values and args.values[1]\n  if selected_profile_value == nil then\n    self:warning(\"Profile selection update skipped because no profile value was provided\")\n    return\n  end\n  profile_select_var = tonumber(selected_profile_value) or selected_profile_value\n  self:updateView(\"select_profile_setup\", \"selectedItem\", \"\"..profile_select_var..\"\")\n  --print(\"profile_select_var\", json.encode(profile_select_var))\n  self.store.profile_selected_trigger = profile_select_var\n  --self:updateView(\"select_profile_setup\", \"selectedItem\", profile_select_var)\n  update_selecteditem()\n  profile_info()\n  --print(\"123\",json.encode(self.store.profile_selected_trigger))\n  p1_on_info()\n  p1_off_info()\n  p1_cha_info()\n  p1_timeinfo()\nend\n\n  --self:updateView(\"select_profile_setup\", \"selectedItem\", profile_select_var)\n -- print(\"123\",json.encode(self.store.profile_selected_trigger))\n  --print(\"profile_select_var\", json.encode(profile_select_var))\n----------------------------------------------------------------------------------------------------------\n\nupdate_selecteditem = function()\n  local p_id = get_selected_profile_id()\n  if p_id == nil then return end\n  --------------\n  self:updateView(\"p1_on\", \"selectedItem\", p1_on[p_id])\n  self:updateView(\"p1_on_delay\", \"selectedItem\", p1_on_delay[p_id])\n  --------------\n  self:updateView(\"p1_off\", \"selectedItem\", p1_off[p_id])\n  self:updateView(\"p1_off_delay\", \"selectedItem\", p1_off_delay[p_id])\n  --------------\n  self:updateView(\"p1_cha\", \"selectedItem\", p1_cha[p_id])\n  self:updateView(\"p1_cha_delay\", \"selectedItem\", p1_cha_delay[p_id])\nend\n\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n----profile label update\nprofile_info = function()\n  local line = \"\"\n  local left = \"<tr><td align =left>\"..color1..\"<font size='\"..(Fontsize+1)..\"'>\"\n  local right = \"</td><td align =right>\"..color2..\"<font size='\"..(Fontsize+1)..\"'>\"\n  local right_end = \"</td></tr>\"\n  local var = \"test\"\n  local p_id = get_selected_profile_id()\n  local active_profile_id = get_active_profile_id()\n  local active_profile_name = \"Unknown\"\n  if p_id == nil then return end\n  if active_profile_id ~= nil then\n    active_profile_name = get_profile_display_name(active_profile_id)\n  end\n  local piron = \"\"        \n  local pirondel = \"\"   \n  local piroff = \"\"  \n  local piroffdel = \"\"  \n  local pircha = \"\"  \n  local pirchadel = \"\"  \n    for ind,val in pairs(update_select_list) do \n      if val.value == p1_on[p_id] then\n        piron = val.text \n      end\n      if val.value == p1_on_delay[p_id] then\n        pirondel = val.text \n      end\n      if val.value == p1_off[p_id] then\n        piroff = val.text \n      end\n      if val.value == p1_off_delay[p_id] then\n        piroffdel = val.text \n      end\n      if val.value == p1_cha[p_id] then\n        pircha = val.text \n      end\n      if val.value == p1_cha_delay[p_id] then\n        pirchadel = val.text \n      end\n\n    end --forloop\n  local function fmt(v) \n    local formatted_value = string.format(\"%02d\",v)\n    return formatted_value\n    end\n  local p1_basic = tonumber(self.store.p1_basic_time[p_id]) or 0\n  local p1_on_delay_t = tonumber(self.store.p1_on_delay_time[p_id]) or 300\n  local p1_off_delay_t = tonumber(self.store.p1_off_delay_time[p_id]) or 300\n  local p1_cha_delay_t = tonumber(self.store.p1_cha_delay_time[p_id]) or 300\n  local p1_priority_t = tonumber(self.store.p1_priority_time[p_id]) or 10\n  local p1_on_basic_sec = fmt(tostring(math.fmod (p1_basic, 60)))\n  local p1_on_basic_min = fmt(tostring(math.floor (p1_basic/60)))\n  local p1_on_delay_sec = fmt(tostring(math.fmod (p1_on_delay_t, 60)))\n  local p1_on_delay_min = fmt(tostring(math.floor (p1_on_delay_t/60)))\n  local p1_off_delay_sec = fmt(tostring(math.fmod (p1_off_delay_t, 60)))\n  local p1_off_delay_min = fmt(tostring(math.floor (p1_off_delay_t/60)))\n  local p1_cha_delay_sec = fmt(tostring(math.fmod (p1_cha_delay_t, 60)))\n  local p1_cha_delay_min = fmt(tostring(math.floor (p1_cha_delay_t/60)))\n  local p1_priority_sec = fmt(tostring(math.fmod (p1_priority_t, 60)))\n  ---translation[\"Room Name: \"]\n  --print(\"profilename\",profil_name[p_id])\n  line = \"<section align='left'><font size='\"..(Fontsize+2)..\"'><tt>\"\n  line = \"\"..line..\"\"..color1..\"The current Profile is: \"..color2..\"\"..active_profile_name..\"\\n\"\n  line = \"\"..line..\"\"..color1..\"\"..translation[\"Setup profile below\"]..\":\\n\"\n  line = \"\"..line..\"<table width=400px border = 1px>\"\n  line = \"\"..line..\"\"..left..\"\"..translation[\"Setup for Profile:\"]..\"\"..right..\"\"..get_profile_display_name(p_id)..\"\"..right_end..\"\"\n  line = \"\"..line..\"\"..left..\"\"..translation[\"Basic Pir Timer\"]..\": \"..right..\"\"..p1_on_basic_min..\":\"..p1_on_basic_sec..\"\"..right_end..\"\"\n  line = \"\"..line..\"\"..left..\"\"..translation[\"Pir On Event2\"]..\": \"..right..\"\"..piron..\"\"..right_end..\"\"\n  line = \"\"..line..\"\"..left..\"\"..translation[\"Pir On Event Delay\"]..\": \"..right..\"\"..pirondel..\"\"..right_end..\"\"\n  line = \"\"..line..\"\"..left..\"\"..translation[\"ON Delay Timer\"]..\": \"..right..\"\"..p1_on_delay_min..\":\"..p1_on_delay_sec..\"\"..right_end..\"\"\n  line = \"\"..line..\"\"..left..\"\"..translation[\"Pir Off Event2\"]..\": \"..right..\"\"..piroff..\"\"..right_end..\"\"\n  line = \"\"..line..\"\"..left..\"\"..translation[\"Pir Off Event Delay2\"]..\": \"..right..\"\"..piroffdel..\"\"..right_end..\"\"\n  line = \"\"..line..\"\"..left..\"\"..translation[\"OFF Delay Timer\"]..\":  \"..right..\"\"..p1_off_delay_min..\":\"..p1_off_delay_sec..\"\"..right_end..\"\"\n  line = \"\"..line..\"\"..left..\"\"..translation[\"Profile Change Event\"]..\": \"..right..\"\"..pircha..\"\"..right_end..\"\"\n  line = \"\"..line..\"\"..left..\"\"..translation[\"Profile Change Event Delay\"]..\": \"..right..\"\"..pirchadel..\"\"..right_end..\"\"\n  line = \"\"..line..\"\"..left..\"\"..translation[\"Change Delay Timer2\"]..\":  \"..right..\"\"..p1_cha_delay_min..\":\"..p1_cha_delay_sec..\"\"..right_end..\"\"\n  line = \"\"..line..\"\"..left..\"\"..translation[\"Change Priority Timer\"]..\": \"..right..\"\"..p1_priority_sec..\"\"..right_end..\"\"\n  line = \"\"..line..\"</table>\"\n    self:updateView(\"profile_info\", \"text\",\" \"..line..\"   </tt></font></section>\")\n  end\n  --profile_info()\n\n\n\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\np1_on_info = function()\n\n    local left = \"<tr><td align =left>\"..color1..\"\"\n    local right = \"</td><td align =right>\"..color2..\"\"\n    local right_end = \"</td></tr>\"\n    local var = \"test\"\n    local p_id = get_selected_profile_id()\n    if p_id == nil then return end\n    --print(\"profilename\",p_id)\n    --print(\"profilename\",profil_name[p_id])\n    local line = \"<table width=400px border = 0px><section align='left'><font size='\"..(Fontsize+2)..\"'><tt>\"\n    line = \"\"..line..\"\"..left..\"\"..translation[\"Setup for Profile:\"]..\" \"..color2..\"\"..get_profile_display_name(p_id)..\" \"\n    line = \"\"..line..\"\"..left..\"\"..translation[\"Choose what should happen:\"]..\" \"..color2..\"\"..translation[\"Pir On Event2\"]..\" \"..color1..\"\"..translation[\"and\"]..\"\"\n    line = \"\"..line..\"\"..left..\"\"..translation[\"Choose what should happen:\"]..\" \"..color2..\"\"..translation[\"Pir On Event Delay\"]..\"\"\n      self:updateView(\"p1_on_info\", \"text\",\" \"..line..\"   </tt></font></section>\")\n    end\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\np1_off_info = function()\n  local left = \"<tr><td align =left>\"..color1..\"\"\n  local right = \"</td><td align =right>\"..color2..\"\"\n  local right_end = \"</td></tr>\"\n  local var = \"test\"\n  local p_id = get_selected_profile_id()\n  if p_id == nil then return end\n\n  local line = \"<table width=400px border = 0px><section align='left'><font size='\"..(Fontsize+2)..\"'><tt>\"\n  line = \"\"..line..\"\"..left..\"\"..translation[\"Setup for Profile:\"]..\" \"..color2..\"\"..get_profile_display_name(p_id)..\" \"\n  line = \"\"..line..\"\"..left..\"\"..translation[\"Choose what should happen:\"]..\" \"..color2..\"\"..translation[\"Pir Off Event2\"]..\" \"..color1..\"\"..translation[\"and\"]..\"\"\n  line = \"\"..line..\"\"..left..\"\"..translation[\"Choose what should happen:\"]..\" \"..color2..\"\"..translation[\"Pir Off Event Delay2\"]..\"\"\n    self:updateView(\"p1_off_info\", \"text\",\" \"..line..\"   </tt></font></section>\")\n  end\n  ----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\np1_cha_info = function()\n  local left = \"<tr><td align =left>\"..color1..\"\"\n  local right = \"</td><td align =right>\"..color2..\"\"\n  local right_end = \"</td></tr>\"\n  local var = \"test\"\n  local p_id = get_selected_profile_id()\n  if p_id == nil then return end\n\n  local line = \"<table width=400px border = 0px><section align='left'><font size='\"..(Fontsize+2)..\"'><tt>\"\n  line = \"\"..line..\"\"..left..\"\"..translation[\"Setup for Profile:\"]..\" \"..color2..\"\"..get_profile_display_name(p_id)..\" \"\n  line = \"\"..line..\"\"..left..\"\"..translation[\"Choose what should happen:\"]..\" \"..color2..\"\"..translation[\"Profile Change Events\"]..\" \"..color1..\"\"..translation[\"and\"]..\"\"\n  line = \"\"..line..\"\"..left..\"\"..translation[\"Choose what should happen:\"]..\" \"..color2..\"\"..translation[\"Profile Change Delay Events\"]..\"\"\n    self:updateView(\"p1_cha_info\", \"text\",\" \"..line..\"   </tt></font></section>\")\n  end\n\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n-----dropdownlist handler for Pir on event \nfunction QuickApp:p1_on(args)\n  --print(\"args.values[1]: \", json.encode(args.values[1]))\n  local var = tostring(args.values[1])\n  local p_id = get_selected_profile_id()\n  if p_id == nil then return end\n    self:updateView(\"p1_on\", \"selectedItem\", \"\"..args.values[1]..\"\")\n    self.store.p1_on_args = \"\"..var..\"\"\n    --self:debug(\"Selected: \",var)\n    --print(\"update_select_profil\",json.encode(update_select_profil))\n    --print(\"self.store.profile_selected_trigger\",json.encode(self.store.profile_selected_trigger))\n    --print(\"update_select_profil.value\",json.encode(update_select_profil.value))\n    --print(\"update_select_profil[1].value\",json.encode(update_select_profil[1].value))\n  \n    p1_on[p_id] = \"\"..var..\"\"\n    --print(\"p1_on[ind]\",json.encode(p1_on))\n    self.store.p1_on= p1_on\n    profile_info()\nend\n--self:updateView(\"p1_on\", \"selectedItem\", self.store.p1_on_args)\n\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n-----dropdownlist handler for Pir on delay event \nfunction QuickApp:p1_on_delay(args)\n  local var = tostring(args.values[1])\n  local p_id = get_selected_profile_id()\n  if p_id == nil then return end\n    self:updateView(\"p1_on_delay\", \"selectedItem\", \"\"..args.values[1]..\"\")\n    self.store.p1_on_delay_args = \"\"..var..\"\"\n    p1_on_delay[p_id] = \"\"..var..\"\"\n    --print(\"p1_on_delay[ind]\",json.encode(p1_on_delay))\n    self.store.p1_on_delay= p1_on_delay\n    profile_info()\nend\n--self:updateView(\"p1_on_delay\", \"selectedItem\", self.store.p1_on_delay_args)\n\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n-----dropdownlist handler for Pir off event \nfunction QuickApp:p1_off(args)\n  local var = tostring(args.values[1])\n  local p_id = get_selected_profile_id()\n  if p_id == nil then return end\n    self:updateView(\"p1_off\", \"selectedItem\", \"\"..args.values[1]..\"\")\n    self.store.p1_off_args = \"\"..var..\"\"\n    p1_off[p_id] = \"\"..var..\"\"\n    --print(\"p1_off[ind]\",json.encode(p1_off))\n    self.store.p1_off= p1_off\n    profile_info()\nend\n--self:updateView(\"p1_off\", \"selectedItem\", self.store.p1_off_args)\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n-----dropdownlist handler for Pir off delay event \nfunction QuickApp:p1_off_delay(args)\n  local var = tostring(args.values[1])\n  local p_id = get_selected_profile_id()\n  if p_id == nil then return end\n    self:updateView(\"p1_off_delay\", \"selectedItem\", \"\"..args.values[1]..\"\")\n    self.store.p1_off_delay_args = \"\"..var..\"\"\n    p1_off_delay[p_id] = \"\"..var..\"\"\n    --print(\"p1_off_delay[ind]\",json.encode(p1_off_delay))\n    self.store.p1_off_delay= p1_off_delay\n    profile_info()\nend\n--self:updateView(\"p1_off_delay\", \"selectedItem\", self.store.p1_off_delay_args)\n\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n-----dropdownlist handler for cha event \nfunction QuickApp:p1_cha(args)\n  local var = tostring(args.values[1])\n  local p_id = get_selected_profile_id()\n  if p_id == nil then return end\n    self:updateView(\"p1_cha\", \"selectedItem\", \"\"..args.values[1]..\"\")\n    self.store.p1_cha_args = \"\"..var..\"\"\n    p1_cha[p_id] = \"\"..var..\"\"\n    --print(\"p1_cha[ind]\",json.encode(p1_cha))\n    self.store.p1_cha= p1_cha\n    profile_info()\nend\n--self:updateView(\"p1_cha\", \"selectedItem\", self.store.p1_cha_args)\n\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n-----dropdownlist handler for cha delay event \nfunction QuickApp:p1_cha_delay(args)\n  local var = tostring(args.values[1])\n  local p_id = get_selected_profile_id()\n  if p_id == nil then return end\n    self:updateView(\"p1_cha_delay\", \"selectedItem\", \"\"..args.values[1]..\"\")\n    self.store.p1_cha_delay_args = \"\"..var..\"\"\n    p1_cha_delay[p_id] = \"\"..var..\"\"\n    --print(\"p1_cha_delay[ind]\",json.encode(p1_cha_delay))\n    self.store.p1_cha_delay= p1_cha_delay\n    profile_info()\nend\n--self:updateView(\"p1_cha_delay\", \"selectedItem\", self.store.p1_cha_delay_args)\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n-----label update Lights\nlocal function info_selectlight()\n    local room_name_line = \"<font size='\"..(Fontsize+2)..\"'>\"..color1..\"\"..translation[\"Room Name: \"]..\"\"..color2..\"\"..build_trailing_icon_text(self_room_name, qa_ui_icons.room)..\"\"\n    local room_id_line = \"\"..color1..\"Room ID: \"..color2..\"\"..build_trailing_icon_text(self_room_id, qa_ui_icons.identifier)..\" <font size='\"..Fontsize..\"'>\"\n    local light_summary_entries = {}\n    local light_list_index = 1\n\n    for _,light_device_id in ipairs(light_ids or {}) do\n      local light_summary_entry = \"\"..color1..\"\"..translation[\"Light Name: \"]..\"\"..color2..\"\"..build_trailing_icon_text(light_name[light_list_index], qa_ui_icons.light)..\" \\n\"..color1..\"\"..translation[\"Light id:\"]..\"\"..color2..\"\"..build_trailing_icon_text(light_device_id, qa_ui_icons.identifier)..\"\"\n      table.insert(light_summary_entries, light_summary_entry)\n      light_list_index = light_list_index + 1\n    end\n\n    local light_summary_text = table.concat(light_summary_entries, \"\\n\")\n    local light_label_text = room_name_line..\"\\n\"..room_id_line\n    if light_summary_text ~= \"\" then\n      light_label_text = light_label_text..\"\\n\"..light_summary_text\n    end\n\n    try_update_view_text(\"info_selectlight\", \"<table width= 350px border = 0px><td align =left><section align='left'><font size='\"..Fontsize..\"'><tt> \"..light_label_text..\"   </tt></font></section>\")\nend\n  info_selectlight()\n----------------------------------------------------------------------------------------------------------\n----update lights choice list on startup\n  local update_light_list = {}\n  local function update_light_list_if()\n    for ind,val in ipairs(light_ids) do\n        if light_ids[ind] ~= nil then\n        update_light_list[ind] = {\n          text = format_dropdown_device_option_text(light_ids[ind], light_name[ind]),\n          type = \"option\",\n          value = \"\"..light_ids[ind]..\"\"\n        }\n        end\n     \n    end\n    self:updateView(\"select_light_setup\", \"options\", update_light_list)\n    self:updateView(\"select_light_setup\", \"selectedItems\", pending_lightid_trigger_select)\n  end \n    update_light_list_if() \n----------------------------------------------------------------------------------------------------------\n-----dropdown list handler for lights choice\n  function QuickApp:select_light_setup(args)\n    pending_lightid_trigger_select = clone_id_list((args and args.values and args.values[1]) or {})\n  end\n\n  local function commit_selected_lights(selected_light_id_list)\n    lightid_trigger = {}\n    for _,selected_light_id in ipairs(selected_light_id_list or {}) do\n      lightid_trigger[selected_light_id] = selected_light_id\n    end\n    lightid_trigger_select = clone_id_list(selected_light_id_list)\n    self.store.lightid_trigger = lightid_trigger\n    self.store.lightid_trigger_select = lightid_trigger_select\n    self:updateView(\"select_light_setup\", \"selectedItems\", lightid_trigger_select)\n    info_selectlight()\n    if refresh_all_scene_info_views ~= nil then\n      refresh_all_scene_info_views()\n    end\n  end\n\n  function QuickApp:save_lights(args)\n    commit_selected_lights(pending_lightid_trigger_select)\n    pulse_ui_control_feedback(\"save_lights\", save_selected_lights_button_idle_text, save_selected_lights_button_active_text, config.ui.buttonFeedbackMs)\n  end\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n----motionsensor label update\nlocal function info_motionsensor()\n    local room_name_line = \"<font size='\"..(Fontsize+2)..\"'>\"..color1..\"\"..translation[\"Room Name: \"]..\"\"..color2..\"\"..build_trailing_icon_text(self_room_name, qa_ui_icons.room)..\"\"\n    local room_id_line = \"\"..color1..\"Room ID: \"..color2..\"\"..build_trailing_icon_text(self_room_id, qa_ui_icons.identifier)..\" <font size='\"..Fontsize..\"'>\"\n    local motion_sensor_summary_entries = {}\n    local motion_sensor_list_index = 1\n\n    for _,motion_sensor_device_id in ipairs(motion_ids or {}) do\n      local motion_sensor_summary_entry = \"\"..color1..\"\"..translation[\"Motion Sensor Name: \"]..\"\"..color2..\"\"..build_trailing_icon_text(motion_name[motion_sensor_list_index], qa_ui_icons.motion)..\" \\n\"..color1..\"\"..translation[\"Motion Sensor id: \"]..\"\"..color2..\"\"..build_trailing_icon_text(motion_sensor_device_id, qa_ui_icons.identifier)..\"\"\n      table.insert(motion_sensor_summary_entries, motion_sensor_summary_entry)\n      motion_sensor_list_index = motion_sensor_list_index + 1\n    end\n\n    local motion_sensor_summary_text = table.concat(motion_sensor_summary_entries, \"\\n\")\n    local motion_sensor_label_text = room_name_line..\"\\n\"..room_id_line\n    if motion_sensor_summary_text ~= \"\" then\n      motion_sensor_label_text = motion_sensor_label_text..\"\\n\"..motion_sensor_summary_text\n    end\n\n    try_update_view_text(\"info_motionsensor\", \"<table width= 350px border = 0px><td align =left><section align='left'><font size='\"..Fontsize..\"'><tt> \"..motion_sensor_label_text..\"   </tt></font></section>\")\nend\n  info_motionsensor()\n----------------------------------------------------------------------------------------------------------\n-----update motion dropdown list on statup\n  local update_motion_list = {}\n  local function update_motion_list_if()\n    for ind,val in ipairs(motion_ids) do\n        if motion_ids[ind] ~= nil then\n        update_motion_list[ind] = {\n          text = format_dropdown_device_option_text(motion_ids[ind], motion_name[ind]),\n          type = \"option\",\n          value = \"\"..motion_ids[ind]..\"\"\n        }\n        end\n   \n    end\n  self:updateView(\"select_motion_setup\", \"options\", update_motion_list)\n  \n  self:updateView(\"select_motion_setup\", \"selectedItems\", motionsensorid_trigger_select)\n  end \n  update_motion_list_if()\n----------------------------------------------------------------------------------------------------------\n-----motionsensor dropdown list handler\n  local var2 = {}\n  function QuickApp:select_motion_setup(args)\n    var2 = (args and args.values and args.values[1]) or {}\n    motionsensorid_trigger = {}\n    for _,selected_motion_id in ipairs(var2) do\n      motionsensorid_trigger[selected_motion_id] = selected_motion_id\n    end\n    self.store.motionsensorid_trigger = motionsensorid_trigger\n    self.store.motionsensorid_trigger_select = var2\n    self:updateView(\"select_motion_setup\", \"selectedItems\", var2)\n    if refresh_motion_sensor_state_cache ~= nil then\n      refresh_motion_sensor_state_cache()\n    end\n    info_motionsensor()\n  end\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n-----------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n----- enable/disable Pir evnets info\ninfo_pir_enable = function()\n  local line1 = \"\"..color1..\"<font size='\"..Fontsize..\"'>\"..build_icon_text(qa_ui_icons.motion, translation[\"info_pir_enable\"])..\"\"\n  if self.store.enable_status == \"off\" then\n  line1= \"\"..line1..\" \"..color3..\"\"..translation[\"info_pir_enable_off\"]..\" \"\n  else\n  line1= \"\"..line1..\" \"..color2..\"\"..translation[\"info_pir_enable_on\"]..\"\"\n  end\n\n  try_update_view_text(\"info_pir_enable\", \"<table width= 350px border = 0px><td align =left><section align='left'><font size='\"..Fontsize..\"'><tt> \"..line1..\"   </tt></font></section>\")\nend\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n---enable motion lights\nfunction QuickApp:enable(args)     \n  self.store.enable_status = \"on\"\n  fibaropir = 0\n  enable_status_fun()\nend\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n---disable motion lights\nfunction QuickApp:disable(args)     \n  self.store.enable_status = \"off\"\n  fibaropir = 0\n  enable_status_fun()\n  cancel_pir_timers()\nend\n\n----------------------------------------------------------------------------------------------------------\nenable_status_fun = function()\n  if self.store.enable_status == \"off\" then\n  self:updateView(\"enable\", \"value\", \"false\")\n  self:updateView(\"disable\", \"value\", \"true\")\n  else\n  self:updateView(\"enable\", \"value\", \"true\")\n  self:updateView(\"disable\", \"value\", \"false\")\n  end\n  enable_status = self.store.enable_status\n  info_pir_enable()\nend\n  enable_status_fun()\n\nlocal function begin_direct_light_action_measurement(action_name, trigger_source)\n  if action_dispatch_measurement_enabled ~= true then\n    return nil\n  end\n\n  return {\n    actionName = tostring(action_name or \"Action\"),\n    hubCallCount = 0,\n    startedAtClock = os.clock(),\n    triggerSource = tostring(trigger_source or \"light_action\"),\n  }\nend\n\nlocal function call_direct_light_action(action_dispatch_measurement, light_device_id, action_name, ...)\n  if action_dispatch_measurement ~= nil then\n    action_dispatch_measurement.hubCallCount = (tonumber(action_dispatch_measurement.hubCallCount) or 0) + 1\n  end\n  return safe_hub_call(light_device_id, action_name, ...)\nend\n\nlocal function finish_direct_light_action_measurement(action_dispatch_measurement, status_suffix)\n  local log_text = nil\n  local debug_text = nil\n  local measurement_summary = nil\n  local measurement_store_key = nil\n  local active_button_names = nil\n\n  if action_dispatch_measurement ~= nil then\n    local elapsed_ms = math.max(0, (os.clock() - (action_dispatch_measurement.startedAtClock or os.clock())) * 1000)\n    measurement_summary = string.format(\n      \"%s %s -> %.1f ms, %d hub.call\",\n      tostring(action_dispatch_measurement.actionName or \"Action\"),\n      tostring(action_dispatch_measurement.triggerSource or \"light_action\"),\n      elapsed_ms,\n      tonumber(action_dispatch_measurement.hubCallCount) or 0\n    )\n\n    if tostring(status_suffix or \"\") ~= \"\" then\n      measurement_summary = measurement_summary..\" (\"..tostring(status_suffix)..\")\"\n    end\n\n    log_text = measurement_summary\n    debug_text = measurement_summary\n    measurement_store_key = \"last_direct_light_action_measurement\"\n\n    if tostring(action_dispatch_measurement.actionName or \"\") == tostring(translation[\"turnOn\"]) then\n      active_button_names = {\"turnon\"}\n    elseif tostring(action_dispatch_measurement.actionName or \"\") == tostring(translation[\"turnOff\"]) then\n      active_button_names = {\"turnoff\"}\n    end\n  end\n\n  schedule_deferred_action_ui_update({\n    activeButtonNames = active_button_names,\n    debugText = debug_text,\n    logText = log_text,\n    measurementStoreKey = measurement_store_key,\n    measurementSummary = measurement_summary,\n  })\nend\n\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n---turnon event/scene\nfunction QuickApp:turnon(args)     \n  turnon(\"turnon_button\")\n  cancel_pir_timers()\nend\n\nturnon = function(trigger_source)\n  cancel_pending_deferred_action_ui_update()\n  local action_dispatch_measurement = begin_direct_light_action_measurement(translation[\"turnOn\"], trigger_source or \"turnOn_action\")\n  local selected_light_ids = self.store.lightid_trigger_select or {}\n  if next(selected_light_ids) == nil then\n    self:warning(\"Turn on skipped because no lights are selected\")\n    if action_dispatch_measurement == nil then\n      schedule_deferred_action_ui_update({\n        activeButtonNames = {\"turnon\"},\n        logText = \"\"..translation[\"turnOn\"]..\"\",\n      })\n    else\n      finish_direct_light_action_measurement(action_dispatch_measurement, \"no lights selected\")\n    end\n    return\n  end\n\n  for _,selected_light_id in ipairs(selected_light_ids) do\n    local light_device_id = tonumber(selected_light_id)\n    if light_device_id ~= nil then\n      call_direct_light_action(action_dispatch_measurement, light_device_id, \"turnOn\")\n    else\n      self:warning(\"Turn on skipped invalid light ID \"..tostring(selected_light_id))\n    end\n  end\n\n  if action_dispatch_measurement == nil then\n    schedule_deferred_action_ui_update({\n      activeButtonNames = {\"turnon\"},\n      logText = \"\"..translation[\"turnOn\"]..\"\",\n    })\n  else\n    finish_direct_light_action_measurement(action_dispatch_measurement)\n  end\nend\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n----turnoff event/scene\nfunction QuickApp:turnoff(args)    \n  turnoff(\"turnoff_button\")\n  cancel_pir_timers()\nend \n\nturnoff = function(trigger_source)\n  cancel_pending_deferred_action_ui_update()\n  local action_dispatch_measurement = begin_direct_light_action_measurement(translation[\"turnOff\"], trigger_source or \"turnOff_action\")\n  local selected_light_ids = self.store.lightid_trigger_select or {}\n  if next(selected_light_ids) == nil then\n    self:warning(\"Turn off skipped because no lights are selected\")\n    if action_dispatch_measurement == nil then\n      schedule_deferred_action_ui_update({\n        activeButtonNames = {\"turnoff\"},\n        logText = \"\"..translation[\"turnOff\"]..\"\",\n      })\n    else\n      finish_direct_light_action_measurement(action_dispatch_measurement, \"no lights selected\")\n    end\n    return\n  end\n\n  for _,selected_light_id in ipairs(selected_light_ids) do\n    local light_device_id = tonumber(selected_light_id)\n    if light_device_id ~= nil then\n      call_direct_light_action(action_dispatch_measurement, light_device_id, \"turnOff\")\n    else\n      self:warning(\"Turn off skipped invalid light ID \"..tostring(selected_light_id))\n    end\n  end\n\n  if action_dispatch_measurement == nil then\n    schedule_deferred_action_ui_update({\n      activeButtonNames = {\"turnoff\"},\n      logText = \"\"..translation[\"turnOff\"]..\"\",\n    })\n  else\n    finish_direct_light_action_measurement(action_dispatch_measurement)\n  end\nend\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\nlocal function time_p(current_time_value)\n  local updated_time_value = tonumber(current_time_value)\n  if self.store.time_cha == 5 then\n    updated_time_value = updated_time_value + 1\n    if updated_time_value > 20 then\n      updated_time_value = 0\n    end\n  else\n    if self.store.sec_min_sensor == \"sec\" then\n      updated_time_value = updated_time_value + 1\n    elseif self.store.sec_min_sensor == \"min\" then\n      updated_time_value = updated_time_value + 60\n    else\n      updated_time_value = updated_time_value + 600 \n    end\n    if updated_time_value > 3600 then\n      updated_time_value = 0\n    end\n  end\n  return updated_time_value\nend\n----------------------------------------------------------------------------------------------------------\nlocal function time_n(current_time_value)\n  local updated_time_value = tonumber(current_time_value)\n  if self.store.time_cha == 5 then\n    updated_time_value = updated_time_value - 1\n    if updated_time_value < 0 then\n      updated_time_value = 20\n    end\n  else\n    if self.store.sec_min_sensor == \"sec\" then\n      updated_time_value = updated_time_value - 1\n    elseif self.store.sec_min_sensor == \"min\" then\n      updated_time_value = updated_time_value - 60\n    else\n      updated_time_value = updated_time_value - 600 \n    end\n    if updated_time_value < 0 then\n      updated_time_value = 3600\n    end\n  end\n  return updated_time_value\nend\n----------------------------------------------------------------------------------------------------------\n-----sensor + button handler\nfunction QuickApp:p1_time_p(args)\n    self:updateView(\"p1_time_p\", \"value\", \"true\")  \n    local p_id = get_selected_profile_id()\n    if p_id == nil then return end\n    --print(\"p_id\",p_id)\n     if        self.store.time_cha == 1 then\n        local val = p1_basic_time[p_id] or 0\n        p1_basic_time[p_id] = time_p(val)\n        self.store.p1_basic_time = p1_basic_time\n    elseif    self.store.time_cha == 2 then\n        local val = p1_on_delay_time[p_id] or 300\n        p1_on_delay_time[p_id] = time_p(val)\n        self.store.p1_on_delay_time = p1_on_delay_time\n    elseif    self.store.time_cha == 3 then\n        local val = p1_off_delay_time[p_id] or 300\n        p1_off_delay_time[p_id] = time_p(val)\n        self.store.p1_off_delay_time = p1_off_delay_time\n    elseif    self.store.time_cha == 4 then\n        local val = p1_cha_delay_time[p_id] or 300\n        p1_cha_delay_time[p_id] = time_p(val)\n        self.store.p1_cha_delay_time = p1_cha_delay_time\n    elseif    self.store.time_cha == 5 then\n        local val = p1_priority_time[p_id] or 10\n        p1_priority_time[p_id] = time_p(val)\n        self.store.p1_priority_time = p1_priority_time\n    end\n  p1_timeinfo()\n  profile_info()\n  hub.setTimeout(200, function() self:updateView(\"p1_time_p\", \"value\", \"false\")  end)\nend\n---------------------------------------------------------------------------------------------------------\n-----sensor - button handler\nfunction QuickApp:p1_time_n(args)\n  self:updateView(\"p1_time_n\", \"value\", \"true\")  \n  local p_id = get_selected_profile_id()\n  if p_id == nil then return end\n  if        self.store.time_cha == 1 then\n    local val = p1_basic_time[p_id] or 0\n    p1_basic_time[p_id] = time_n(val)\n    self.store.p1_basic_time = p1_basic_time\nelseif    self.store.time_cha == 2 then\n    local val = p1_on_delay_time[p_id] or 300\n    p1_on_delay_time[p_id] = time_n(val)\n    self.store.p1_on_delay_time = p1_on_delay_time\nelseif    self.store.time_cha == 3 then\n    local val = p1_off_delay_time[p_id] or 300\n    p1_off_delay_time[p_id] = time_n(val)\n    self.store.p1_off_delay_time = p1_off_delay_time\nelseif    self.store.time_cha == 4 then\n    local val = p1_cha_delay_time[p_id] or 300\n    p1_cha_delay_time[p_id] = time_n(val)\n    self.store.p1_cha_delay_time = p1_cha_delay_time\nelseif    self.store.time_cha == 5 then\n    local val = p1_priority_time[p_id] or 10\n    p1_priority_time[p_id] = time_n(val)\n    self.store.p1_priority_time = p1_priority_time\nend\n  p1_timeinfo()\n  profile_info()\n  hub.setTimeout(200, function()   self:updateView(\"p1_time_n\", \"value\", \"false\")   end)\nend\n----------------------------------------------------------------------------------------------------------\n-----sensor min/sec button handler\nlocal function refresh_time_unit_mode_button()\n  local current_time_unit_mode = normalize_time_unit_mode(self.store.sec_min_sensor)\n  self.store.sec_min_sensor = current_time_unit_mode\n\n  if current_time_unit_mode == \"min\" then\n    try_update_view_text(\"p1_time_minsec\", build_icon_text(qa_ui_icons.timer, translation[\"Min\"]))\n  elseif current_time_unit_mode == \"minx10\" then\n    try_update_view_text(\"p1_time_minsec\", build_icon_text(qa_ui_icons.timer, \"10 \"..translation[\"Min\"]))\n  else\n    try_update_view_text(\"p1_time_minsec\", build_icon_text(qa_ui_icons.timer, translation[\"Sec\"]))\n  end\nend\n\nlocal function cycle_time_unit_mode()\n  local current_time_unit_mode = normalize_time_unit_mode(self.store.sec_min_sensor)\n  if current_time_unit_mode == \"sec\" then\n    self.store.sec_min_sensor = \"min\"\n  elseif current_time_unit_mode == \"min\" then\n    self.store.sec_min_sensor = \"minx10\"\n  else\n    self.store.sec_min_sensor = \"sec\"\n  end\n\n  refresh_time_unit_mode_button()\nend\n\nfunction QuickApp:p1_time_minsec(args)\n  self:updateView(\"p1_time_minsec\", \"value\", \"true\") \n  cycle_time_unit_mode()\n  hub.setTimeout(200, function() self:updateView(\"p1_time_minsec\", \"value\", \"false\") end)\nend\nrefresh_time_unit_mode_button()\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n\n--[[\n  self.store.p1_basic_time = {0,0,0,0}\n  self.store.p1_on_delay_time = {300,300,300,300}\n  self.store.p1_off_delay_time = {300,300,300,300}\n  self.store.p1_cha_delay_time = {300,300,300,300}\n  self.store.p1_priority_time = {300,300,300,300}\n]]\n\n\n\n\nfunction QuickApp:p1_time_cha(args)\n  self:updateView(\"p1_time_cha\", \"value\", \"true\") \n  p1_time_cha()\n  p1_timeinfo()\n  hub.setTimeout(200, function()   self:updateView(\"p1_time_cha\", \"value\", \"false\")   end)\nend\n\n----------------------------------------------------------------------------------------------------------\np1_time_cha = function()\n    local current_time_selection_mode = normalize_time_selection_mode(self.store.time_cha)\n    if current_time_selection_mode >= 5 then\n      self.store.time_cha = 1\n    else\n      self.store.time_cha = current_time_selection_mode + 1\n    end\n    self.store.p1_time_cha = self.store.time_cha\n    --print(\"self.store.time_cha\",self.store.time_cha)\n  end\n----------------------------------------------------------------------------------------------------------\n----Sensor time label updater and time converter\np1_timeinfo = function()\n  local Fontsize = Fontsize + 2\n  local left = \"<tr><td align =left>\"..color1..\"\"\n  local right = \"</td><td align =right>\"..color3..\"\" --rød\n  local right2 = \"</td><td align =right>\"..color2..\"\"  --grønn\n  local right_end = \"</td></tr>\"\n  local var = \"test\"\n  local p_id = get_selected_profile_id()\n  if p_id == nil then return end\n  local function fmt(v) \n        local formatted_value = string.format(\"%02d\",v)\n        return formatted_value\n        end\n  local p1_basic = tonumber(self.store.p1_basic_time[p_id]) or 0\n  local p1_on_delay_t = tonumber(self.store.p1_on_delay_time[p_id]) or 300\n  local p1_off_delay_t = tonumber(self.store.p1_off_delay_time[p_id]) or 300\n  local p1_cha_delay_t = tonumber(self.store.p1_cha_delay_time[p_id]) or 300\n  local p1_priority_t = tonumber(self.store.p1_priority_time[p_id]) or 10\n  local p1_on_basic_sec = fmt(tostring(math.fmod (p1_basic, 60)))\n  local p1_on_basic_min = fmt(tostring(math.floor (p1_basic/60)))\n  local p1_on_delay_sec = fmt(tostring(math.fmod (p1_on_delay_t, 60)))\n  local p1_on_delay_min = fmt(tostring(math.floor (p1_on_delay_t/60)))\n  local p1_off_delay_sec = fmt(tostring(math.fmod (p1_off_delay_t, 60)))\n  local p1_off_delay_min = fmt(tostring(math.floor (p1_off_delay_t/60)))\n  local p1_cha_delay_sec = fmt(tostring(math.fmod (p1_cha_delay_t, 60)))\n  local p1_cha_delay_min = fmt(tostring(math.floor (p1_cha_delay_t/60)))\n  local p1_priority_sec = fmt(tostring(math.fmod (p1_priority_t, 60)))\n---- basic sensor delay,delay on, delay off, delay cha, delay priority cha,\nlocal s1 = \"\" \nlocal s2 = \"\" \nlocal s3 = \"\" \nlocal s4 = \"\"\nlocal s5 = \"\"\nif self.store.time_cha == 1 then\n  s1 = \"\"..color2..\"\"\nelseif self.store.time_cha == 2 then\n  s2 = \"\"..color2..\"\"\nelseif self.store.time_cha == 3 then\n  s3 = \"\"..color2..\"\"\nelseif self.store.time_cha == 4 then\n  s4 = \"\"..color2..\"\"\nelseif self.store.time_cha == 5 then\n  s5 = \"\"..color2..\"\"\nend\n  local line = \"\"\n  --math.fmod (x, y)\n  line = \"\"..line..\"\"..left..\"\"..translation[\"setup profile\"]..\": \"..right2..\"\"..get_profile_display_name(p_id)..\" \"..right_end..\"\"\n\n  line = \"\"..line..\"\"..left..\"\"..translation[\"Basic Sensor Time\"]..\": \"..right..\"\"..s1..\"\"..p1_on_basic_min..\":\"..p1_on_basic_sec..\"\"..right_end..\"\"\n\n  line = \"\"..line..\"\"..left..\"\"..translation[\"Delay ON\"]..\": \"..right..\"\"..s2..\"\"..p1_on_delay_min..\":\"..p1_on_delay_sec..\"\"..right_end..\"\" \n\n  line = \"\"..line..\"\"..left..\"\"..translation[\"Delay OFF\"]..\": \"..right..\"\"..s3..\"\"..p1_off_delay_min..\":\"..p1_off_delay_sec..\"\"..right_end..\"\"\n\n  line = \"\"..line..\"\"..left..\"\"..translation[\"Delay profile\"]..\": \"..right..\"\"..s4..\"\"..p1_cha_delay_min..\":\"..p1_cha_delay_sec..\"\"..right_end..\"\"\n\n  line = \"\"..line..\"\"..left..\"\"..translation[\"Delay Priority\"]..\": \"..right..\"\"..s5..\"\"..p1_priority_sec..\" sec\"..right_end..\" \" \n -- line = \"\"..line..\"\"..left..\" \"..right..\" \"..right_end..\"\"\n\n  self:updateView(\"p1_timeinfo\",\"text\",\"  <table width= 400px border = 0px><td align =left><section align='left'><font size='\"..Fontsize..\"'><tt> \"..line..\"  </tt></font></section>\")\nend\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\nlocal function get_scene_snapshot_store(scene_no, store_suffix)\n  return self.store[\"scene\"..scene_no..\"_\"..store_suffix] or {}\nend\n\nlocal function get_scene_snapshot_value(scene_store, light_device_id, light_position)\n  local light_device_key = tostring(light_device_id)\n  if scene_store[light_device_key] ~= nil then return scene_store[light_device_key] end\n  if scene_store[tonumber(light_device_id)] ~= nil then return scene_store[tonumber(light_device_id)] end\n  if scene_store[light_position] ~= nil then return scene_store[light_position] end\n  if scene_store[tostring(light_position)] ~= nil then return scene_store[tostring(light_position)] end\n  return nil\nend\n\nlocal function get_color_program_name(color_program_id)\n  local color_program_string = tostring(color_program_id)\n  if color_program_string == \"1\" then return translation[\"Fire\"] end\n  if color_program_string == \"2\" then return translation[\"Storm\"] end\n  if color_program_string == \"3\" then return translation[\"RGB\"] end\n  if color_program_string == \"4\" then return translation[\"Aurora\"] end\n  if color_program_string == \"5\" then return translation[\"Police\"] end\n  if color_program_string == \"0\" then return translation[\"No Program\"] end\n  return nil\nend\n\nlocal function build_color_component_table(color_value)\n  if color_value == nil then\n    return nil\n  end\n\n  if type(color_value) == \"table\" then\n    return {\n      red = tonumber(color_value.red or color_value[1]) or 0,\n      green = tonumber(color_value.green or color_value[2]) or 0,\n      blue = tonumber(color_value.blue or color_value[3]) or 0,\n      warmWhite = tonumber(color_value.warmWhite or color_value.white or color_value[4]) or 0,\n    }\n  end\n\n  local color_value_string = tostring(color_value)\n  if color_value_string == \"\" or string.lower(color_value_string) == \"nil\" then\n    return nil\n  end\n\n  local color_components = {}\n  for component_value in string.gmatch(color_value_string, '([^,]+)') do\n    table.insert(color_components, tonumber(component_value) or 0)\n  end\n\n  if #color_components < 3 then\n    return nil\n  end\n\n  return {\n    red = color_components[1] or 0,\n    green = color_components[2] or 0,\n    blue = color_components[3] or 0,\n    warmWhite = color_components[4] or 0,\n  }\nend\n\nlocal function save_scene_snapshot(scene_no)\n  local selected_light_ids = self.store.lightid_trigger_select or {}\n  local scene_value_by_device_id = {}\n  local scene_color_components_by_device_id = {}\n  local scene_color_string_by_device_id = {}\n  local scene_color_program_by_device_id = {}\n\n  if next(selected_light_ids) == nil then\n    self:warning(\"Scene \"..tostring(scene_no)..\" save skipped because no lights are selected\")\n    return\n  end\n\n  for _,selected_light_id in ipairs(selected_light_ids) do\n    local light_device_id = tonumber(selected_light_id)\n    if light_device_id ~= nil then\n      local light_device_key = tostring(light_device_id)\n      local current_color_value = safe_hub_get_value(light_device_id, \"color\", \"Unable to save light color\")\n      scene_value_by_device_id[light_device_key] = safe_hub_get_value(light_device_id, \"value\", \"Unable to save light value\")\n      scene_color_components_by_device_id[light_device_key] = build_color_component_table(current_color_value)\n      scene_color_string_by_device_id[light_device_key] = current_color_value ~= nil and tostring(current_color_value) or nil\n      scene_color_program_by_device_id[light_device_key] = safe_hub_get_value(light_device_id, \"currentProgramID\", \"Unable to save light color program\")\n    else\n      self:warning(\"Scene \"..tostring(scene_no)..\" save skipped invalid light ID \"..tostring(selected_light_id))\n    end\n  end\n\n  self.store[\"scene\"..scene_no..\"_value\"] = scene_value_by_device_id\n  self.store[\"scene\"..scene_no..\"_color\"] = scene_color_components_by_device_id\n  self.store[\"scene\"..scene_no..\"_color_string\"] = scene_color_string_by_device_id\n  self.store[\"scene\"..scene_no..\"_color_program\"] = scene_color_program_by_device_id\nend\n\nlocal function begin_scene_dispatch_measurement(scene_name, trigger_source)\n  if action_dispatch_measurement_enabled ~= true then\n    return nil\n  end\n\n  return {\n    hubCallCount = 0,\n    sceneName = tostring(scene_name or \"Scene\"),\n    startedAtClock = os.clock(),\n    triggerSource = tostring(trigger_source or \"scene_dispatch\"),\n  }\nend\n\nlocal function call_scene_light_action(scene_dispatch_measurement, light_device_id, action_name, ...)\n  if scene_dispatch_measurement ~= nil then\n    scene_dispatch_measurement.hubCallCount = (tonumber(scene_dispatch_measurement.hubCallCount) or 0) + 1\n  end\n  return safe_hub_call(light_device_id, action_name, ...)\nend\n\nlocal function finish_scene_dispatch_measurement(scene_dispatch_measurement, status_suffix)\n  if scene_dispatch_measurement == nil then\n    return nil\n  end\n\n  local summary = string.format(\n    \"%s %s -> %.1f ms, %d hub.call\",\n    tostring(scene_dispatch_measurement.sceneName or \"Scene\"),\n    tostring(scene_dispatch_measurement.triggerSource or \"scene_dispatch\"),\n    math.max(0, (os.clock() - (scene_dispatch_measurement.startedAtClock or os.clock())) * 1000),\n    tonumber(scene_dispatch_measurement.hubCallCount) or 0\n  )\n\n  if tostring(status_suffix or \"\") ~= \"\" then\n    summary = summary..\" (\"..tostring(status_suffix)..\")\"\n  end\n\n  return summary\nend\n\nlocal function apply_scene_color(light_device_id, color_component_table, raw_color_value, scene_dispatch_measurement)\n  local normalized_color_components = color_component_table\n  if type(normalized_color_components) ~= \"table\" and raw_color_value ~= nil then\n    normalized_color_components = build_color_component_table(raw_color_value)\n  end\n\n  if type(normalized_color_components) ~= \"table\" then\n    self:warning(\"Skipped RGB apply for light \"..tostring(light_device_id)..\" because color data is invalid: \"..tostring(raw_color_value or color_component_table))\n    return\n  end\n\n  call_scene_light_action(\n    scene_dispatch_measurement,\n    light_device_id,\n    \"setColor\",\n    tonumber(normalized_color_components.red) or 0,\n    tonumber(normalized_color_components.green) or 0,\n    tonumber(normalized_color_components.blue) or 0,\n    tonumber(normalized_color_components.warmWhite) or 0\n  )\nend\n\nlocal function apply_scene_snapshot(scene_no, scene_name, scene_dispatch_measurement)\n  cancel_pending_deferred_action_ui_update()\n  local selected_light_ids = self.store.lightid_trigger_select or {}\n  local scene_value_by_device_id = get_scene_snapshot_store(scene_no, \"value\")\n  local scene_color_components_by_device_id = get_scene_snapshot_store(scene_no, \"color\")\n  local scene_color_string_by_device_id = get_scene_snapshot_store(scene_no, \"color_string\")\n  local scene_color_program_by_device_id = get_scene_snapshot_store(scene_no, \"color_program\")\n  local delayed_program_actions = {}\n\n  if next(selected_light_ids) == nil then\n    self:warning(\"Scene \"..scene_name..\" apply skipped because no lights are selected\")\n    local scene_measurement_summary = finish_scene_dispatch_measurement(scene_dispatch_measurement, \"no lights selected\")\n    schedule_deferred_action_ui_update({\n      debugText = scene_measurement_summary,\n      logText = scene_measurement_summary or scene_name,\n      measurementStoreKey = scene_measurement_summary ~= nil and \"last_scene_dispatch_measurement\" or nil,\n      measurementSummary = scene_measurement_summary,\n    })\n    return\n  end\n\n  for selected_index,selected_light_id in ipairs(selected_light_ids) do\n    local light_device_id = tonumber(selected_light_id)\n    if light_device_id ~= nil then\n      local stored_light_value = get_scene_snapshot_value(scene_value_by_device_id, light_device_id, selected_index)\n      local stored_light_color_components = get_scene_snapshot_value(scene_color_components_by_device_id, light_device_id, selected_index)\n      local stored_light_color_string = get_scene_snapshot_value(scene_color_string_by_device_id, light_device_id, selected_index)\n      local stored_color_program = get_scene_snapshot_value(scene_color_program_by_device_id, light_device_id, selected_index)\n      local color_program_string = tostring(stored_color_program)\n      local normalized_light_value = tonumber(stored_light_value)\n      if normalized_light_value == nil and (stored_light_value == true or tostring(stored_light_value) == \"true\") then\n        normalized_light_value = true\n      elseif normalized_light_value == nil and (stored_light_value == false or tostring(stored_light_value) == \"false\") then\n        normalized_light_value = false\n      end\n\n      if color_program_string == \"1\" or color_program_string == \"2\" or color_program_string == \"3\" or color_program_string == \"4\" or color_program_string == \"5\" then\n        if normalized_light_value ~= nil and normalized_light_value ~= true and normalized_light_value ~= false then\n          call_scene_light_action(scene_dispatch_measurement, light_device_id, \"setValue\", normalized_light_value)\n        end\n        table.insert(delayed_program_actions, {\n          light_device_id = light_device_id,\n          color_program_id = stored_color_program,\n        })\n      else\n        if stored_light_color_components == nil and stored_light_color_string ~= nil then\n          stored_light_color_components = build_color_component_table(stored_light_color_string)\n        end\n\n        if normalized_light_value == true then\n          call_scene_light_action(scene_dispatch_measurement, light_device_id, \"turnOn\")\n        elseif normalized_light_value == false then\n          call_scene_light_action(scene_dispatch_measurement, light_device_id, \"turnOff\")\n        elseif normalized_light_value ~= nil then\n          call_scene_light_action(scene_dispatch_measurement, light_device_id, \"setValue\", normalized_light_value)\n        end\n\n        if stored_light_color_components ~= nil and normalized_light_value ~= false and normalized_light_value ~= 0 then\n          apply_scene_color(light_device_id, stored_light_color_components, stored_light_color_string, scene_dispatch_measurement)\n        end\n      end\n    else\n      self:warning(\"Scene \"..scene_name..\" apply skipped invalid light ID \"..tostring(selected_light_id))\n    end\n  end\n\n  if next(delayed_program_actions) ~= nil then\n    hub.setTimeout(color_transit_time, function()\n      for _,delayed_program_action in ipairs(delayed_program_actions) do\n        call_scene_light_action(\n          scene_dispatch_measurement,\n          delayed_program_action.light_device_id,\n          \"startProgram\",\n          delayed_program_action.color_program_id\n        )\n      end\n      local scene_measurement_summary = finish_scene_dispatch_measurement(scene_dispatch_measurement)\n      schedule_deferred_action_ui_update({\n        activeButtonNames = {\"scene\"..scene_no..\"_set\", \"scene\"..scene_no..\"_set2\"},\n        currentScene = \"\"..scene_name..\"\",\n        debugText = scene_measurement_summary,\n        logText = scene_measurement_summary or scene_name,\n        measurementStoreKey = scene_measurement_summary ~= nil and \"last_scene_dispatch_measurement\" or nil,\n        measurementSummary = scene_measurement_summary,\n      })\n    end)\n  else\n    local scene_measurement_summary = finish_scene_dispatch_measurement(scene_dispatch_measurement)\n    schedule_deferred_action_ui_update({\n      activeButtonNames = {\"scene\"..scene_no..\"_set\", \"scene\"..scene_no..\"_set2\"},\n      currentScene = \"\"..scene_name..\"\",\n      debugText = scene_measurement_summary,\n      logText = scene_measurement_summary or scene_name,\n      measurementStoreKey = scene_measurement_summary ~= nil and \"last_scene_dispatch_measurement\" or nil,\n      measurementSummary = scene_measurement_summary,\n    })\n  end\nend\n\nlocal function update_scene_info_view(scene_no, scene_name, view_name)\n  local scene_header_line = \"\"..color1..\"\"..build_icon_text(qa_ui_icons.save, translation[\"Hold Down to save: \"])..\"\\n <font size='\"..(Fontsize+2)..\"'>\"..color2..\"\"..build_icon_text(qa_ui_icons.scene, scene_name)..\"<font size='\"..Fontsize..\"'>\"\n  local scene_body_entries = {}\n  local selected_light_ids = self.store.lightid_trigger_select or {}\n  local scene_value_by_device_id = get_scene_snapshot_store(scene_no, \"value\")\n  local scene_color_string_by_device_id = get_scene_snapshot_store(scene_no, \"color_string\")\n  local scene_color_program_by_device_id = get_scene_snapshot_store(scene_no, \"color_program\")\n  local name_label_text = \"Name:\"\n  local value_label_text = \"Value:\"\n  local color_label_text = build_icon_text(qa_ui_icons.color, \"Color:\")\n  local program_label_text = build_icon_text(qa_ui_icons.program, \"Program:\")\n\n  for selected_index,selected_light_id in ipairs(selected_light_ids) do\n    local light_device_id = tonumber(selected_light_id)\n    if light_device_id ~= nil then\n      local light_display_name = light_name_by_id[tostring(light_device_id)] or (\"ID \"..tostring(light_device_id))\n      local stored_light_value = get_scene_snapshot_value(scene_value_by_device_id, light_device_id, selected_index)\n      local stored_color_string = get_scene_snapshot_value(scene_color_string_by_device_id, light_device_id, selected_index)\n      local stored_color_program = get_scene_snapshot_value(scene_color_program_by_device_id, light_device_id, selected_index)\n      local light_value_text = stored_light_value ~= nil and tostring(stored_light_value) or \"No Data\"\n      local scene_entry_lines = {\n        \"\"..color1..\"\"..name_label_text..\" \"..color2..\"\"..build_trailing_icon_text(light_display_name, qa_ui_icons.light)..\"\",\n        \"\"..color1..\"\"..value_label_text..\" \"..color2..\"\"..build_trailing_icon_text(light_value_text, qa_ui_icons.value)..\"\",\n      }\n\n      if stored_color_string ~= nil and tostring(stored_color_string) ~= \"nil\" then\n        local color_value_text = \"\"..color1..\"\"..color_label_text..\" \"..color2..\"\"..tostring(stored_color_string)..\" \"..color1..\" (\"..color3..\"\"..translation[\"Red\"]..\", \"..color2..\"\"..translation[\"Green\"]..\", <font color=Blue>\"..translation[\"Blue\"]..\", <font color=white>\"..translation[\"white\"]..\"\"..color1..\")\"\n        table.insert(scene_entry_lines, color_value_text)\n      end\n\n      local color_program_name = get_color_program_name(stored_color_program)\n      if color_program_name ~= nil then\n        local color_program_text = \"\"..color1..\"\"..program_label_text..\" \"..color2..\"\"..color_program_name..\"\"\n        table.insert(scene_entry_lines, color_program_text)\n      end\n\n      table.insert(scene_body_entries, table.concat(scene_entry_lines, \"\\n\"))\n    end\n  end\n\n  local scene_body_text = table.concat(scene_body_entries, \"\\n\")\n  local scene_label_text = scene_header_line\n  if scene_body_text ~= \"\" then\n    scene_label_text = scene_label_text..\"\\n\"..scene_body_text\n  end\n\n  try_update_view_text(view_name, \"<table width= 350px border = 0px><td align =left><section align='left'><font size='\"..Fontsize..\"'><tt> \"..scene_label_text..\"   </tt></font></section>\")\nend\n\nlocal function get_scene_display_name(scene_number)\n  return scene_name_by_number[scene_number] or (\"Scene \"..tostring(scene_number))\nend\n\nlocal function refresh_scene_info_view_by_number(scene_number)\n  update_scene_info_view(scene_number, get_scene_display_name(scene_number), \"scene\"..scene_number..\"_info\")\nend\n\nrun_scene_snapshot_by_number = function(scene_number, scene_dispatch_measurement)\n  apply_scene_snapshot(scene_number, get_scene_display_name(scene_number), scene_dispatch_measurement)\nend\n\nrefresh_all_scene_info_views = function()\n  for scene_number = 1, #scene_name_by_number do\n    refresh_scene_info_view_by_number(scene_number)\n  end\nend\n\nfor scene_number = 1, #scene_name_by_number do\n  local current_scene_number = scene_number\n  self:updateView(\"scene\"..current_scene_number..\"_save\", \"value\", \"true\")\nend\n\ndispatch_scene_save_callback = function(scene_owner, scene_number, scene_save_control_name, args)\n  scene_owner:updateView(scene_save_control_name, \"value\", \"false\")\n  save_scene_snapshot(scene_number)\n  refresh_scene_info_view_by_number(scene_number)\n  scene_owner:updateView(scene_save_control_name, \"value\", \"true\")\nend\n\ndispatch_scene_activate_callback = function(scene_owner, scene_number, trigger_source, args)\n  local scene_name = get_scene_display_name(scene_number)\n  local scene_dispatch_measurement = begin_scene_dispatch_measurement(scene_name, trigger_source)\n  run_scene_snapshot_by_number(scene_number, scene_dispatch_measurement)\n  cancel_pir_timers()\nend\n\nrefresh_all_scene_info_views()\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n------jgab eventlib handler and filters\nlocal function normalize_motion_value(value)\n  if value == true or value == 1 then return true end\n  if value == false or value == 0 then return false end\n  local v = string.lower(tostring(value))\n  if v == \"true\" or v == \"1\" or v == \"detected\" or v == \"open\" or v == \"opened\" then return true end\n  if v == \"false\" or v == \"0\" or v == \"safe\" or v == \"close\" or v == \"closed\" then return false end\n  return nil\nend\n\nlocal function is_selected_motion_sensor(selected_map, sensor_id)\n  local id_str = tostring(sensor_id)\n  local id_num = tonumber(sensor_id)\n  if selected_map[id_str] ~= nil then return true end\n  if id_num ~= nil and selected_map[id_num] ~= nil then return true end\n  return false\nend\n\nlocal function update_cached_motion_sensor_state(motion_sensor_device_id, motion_sensor_value)\n  local normalized_motion_state = normalize_motion_value(motion_sensor_value)\n  if motion_sensor_device_id ~= nil and normalized_motion_state ~= nil then\n    motion_sensor_state_by_device_id[tostring(motion_sensor_device_id)] = normalized_motion_state\n  end\n  return normalized_motion_state\nend\n\nlocal function is_any_selected_motion_sensor_active()\n  for _,selected_motion_sensor_id in pairs(motionsensorid_trigger or {}) do\n    if motion_sensor_state_by_device_id[tostring(selected_motion_sensor_id)] == true then\n      return true\n    end\n  end\n  return false\nend\n\nrefresh_motion_sensor_state_cache = function()\n  local active_motion_sensor_count = 0\n\n  for _,selected_motion_sensor_id in pairs(motionsensorid_trigger or {}) do\n    local motion_sensor_device_id = tonumber(selected_motion_sensor_id)\n    if motion_sensor_device_id ~= nil then\n      local current_motion_sensor_value = safe_hub_get_value(\n        motion_sensor_device_id,\n        \"value\",\n        \"Unable to initialize motion sensor state\"\n      )\n      local normalized_motion_state = update_cached_motion_sensor_state(\n        motion_sensor_device_id,\n        current_motion_sensor_value\n      )\n      if normalized_motion_state == true then\n        active_motion_sensor_count = active_motion_sensor_count + 1\n      end\n    else\n      self:warning(\"Skipped motion sensor state initialization for invalid device ID \"..tostring(selected_motion_sensor_id))\n    end\n  end\n\n  if active_motion_sensor_count > 0 then\n    fibaropir = 1\n    self.store.pir_status = \"Detected\"\n  else\n    fibaropir = 0\n    self.store.pir_status = \"Safe\"\n  end\nend\n\nlocal Check_motionsensorid = false\nfor ind,val in pairs(motionsensorid) do\nCheck_motionsensorid = true\nend ---forloop\n--------------------------------------------\nif (Check_motionsensorid == true) then\n    Event.id='_'\n    Event_std.tagColor='Orange'\n    Event {type='device', id={motionsensorid}, property='value', value='$value'}\n    function Event:handler(event)\n          --self:debug(\"Sensor ID: \",event.id,\"value: \",event.value)\n          --print(\"Event motionsensorid_trigger:\", json.encode(motionsensorid_trigger))\n          local motion_state = update_cached_motion_sensor_state(event.id, event.value)\n          --print(\"motionsensorid_trigger \",motionsensorid_trigger[var])\n            if enable_status == \"on\" then\n              self:debug(\"Sensor ID: \",event.id,\"value: \",event.value,\" Pir: Enabled\")\n              if is_selected_motion_sensor(motionsensorid_trigger, event.id) then \n                --self:debug(\"Sensor ID: \",event.id,\"value: \",event.value)\n                if (motion_state == true) then \n                    cancel_pir_timers()\n                      if fibaropir == 0 then\n                        funpirstatuson()\n                        fibaropir = 1\n                      end\n                elseif (motion_state == false) then\n                  fibaro_pir_check_off()\n                end\n              else\n              return \n              end  --if motionsensorid_trigger[var] == var then \n            else\n              self:debug(\"Sensor ID: \",event.id,\"value: \",event.value,\" Pir: Disabled\")\n            end  --if enable_status == \"on\" then\n    end ---function eventlib\nend\nrefresh_motion_sensor_state_cache()\n\n\n\n------------------------------------------------------------------------------------------------\n  local p1_pir_timer\n  local p1_pir_timer_delay\n  local p1_pir_timer_delay_on\n  local p1_profile_cha_delay\n  local p1_profile_priority\n  cancel_pir_timers = function()\n    if p1_pir_timer ~= nil then hub.clearTimeout(p1_pir_timer); p1_pir_timer = nil end\n    if p1_pir_timer_delay ~= nil then hub.clearTimeout(p1_pir_timer_delay); p1_pir_timer_delay = nil end\n    if p1_pir_timer_delay_on ~= nil then hub.clearTimeout(p1_pir_timer_delay_on); p1_pir_timer_delay_on = nil end\n  end\n\n  cancel_profile_change_timers = function()\n    if p1_profile_cha_delay ~= nil then hub.clearTimeout(p1_profile_cha_delay); p1_profile_cha_delay = nil end\n    if p1_profile_priority ~= nil then hub.clearTimeout(p1_profile_priority); p1_profile_priority = nil end\n\n  end\n\n\n------------------------------------------------------------------------------------------------\nfibaro_pir_check_off = function()\n  profil_id_active = get_active_profile_id()\n  if profil_id_active == nil then\n    self:warning(\"Unable to start PIR off timer because no active profile is available\")\n    return\n  end\n  if is_any_selected_motion_sensor_active() then\n    fibaropir = 1\n    return\n  end\n  if p1_pir_timer ~= nil then\n    return\n  end\n  local time = tonumber(self.store.p1_basic_time[profil_id_active]) or 0\n  --print(\"p1_basic_time OFF\",json.encode(time))\n  p1_pir_timer = hub.setTimeout(time*1000, function()  \n  p1_pir_timer = nil\n  fibaropir = 0\n  motionsensorid_off()\n  end)---- end p1_pir_timer\nend----function \n\n\n\n\n------------------------------------------------------------------------------------------------\nmotionsensorid_off = function()\n  if fibaropir == 0 then\n          funPirStatusOff()\n          --print(\"test2\")\n  end\nend\n--Event:post({type='device', id=PirFibaroID, property='value', value=fibaro.getValue(PirFibaroID,'value')})\n------------------------------------------------------------------------------------------------\n\n\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n----status of pir \nfunpirstatuson = function()\n  self.store.pir_status = \"Detected\"\n  check_pir_on_p1()\nend\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n----status of pir \nfunPirStatusOff = function()\n  self.store.pir_status = \"Safe\"\n  check_pir_off_p1()\nend\n\nlocal action_handler_by_name = {\n  turnOff = function()\n    turnoff(\"turnOff_action\")\n  end,\n  turnOn = function()\n    turnon(\"turnOn_action\")\n  end,\n}\n\nfor scene_number = 1, #scene_name_by_number do\n  local current_scene_number = scene_number\n  action_handler_by_name[\"scene\"..current_scene_number] = function()\n    run_scene_snapshot_by_number(current_scene_number)\n  end\nend\n\n-- Profile-change Follow PIR should reuse the current PIR state without restarting PIR timers.\nlocal function get_effective_pir_status()\n  if fibaropir == 1 or self.store.pir_status == \"Detected\" or is_any_selected_motion_sensor_active() then\n    return \"Detected\"\n  end\n\n  return \"Safe\"\nend\n\nlocal function resolve_follow_pir_action_name(profile_id_for_action)\n  local resolved_profile_id = tonumber(profile_id_for_action) or get_active_profile_id()\n  if resolved_profile_id == nil then\n    return nil\n  end\n\n  local effective_pir_status = get_effective_pir_status()\n  self.store.pir_status = effective_pir_status\n\n  if effective_pir_status == \"Detected\" then\n    return self.store.p1_on[resolved_profile_id], effective_pir_status\n  end\n\n  return self.store.p1_off[resolved_profile_id], effective_pir_status\nend\n\nlocal function execute_configured_light_action(configured_action_name, allow_follow_pir_action, profile_id_for_action)\n  local configured_action_handler = action_handler_by_name[configured_action_name]\n  if configured_action_handler ~= nil then\n    configured_action_handler()\n    return true, false\n  elseif configured_action_name == \"follow_pir\" and allow_follow_pir_action == true then\n    local resolved_action_name = resolve_follow_pir_action_name(profile_id_for_action)\n    if resolved_action_name == \"follow_pir\" then\n      self:warning(\"Follow PIR target action cannot also be Follow PIR\")\n      return false, false\n    end\n\n    return execute_configured_light_action(resolved_action_name, false, profile_id_for_action)\n  elseif configured_action_name == \"no_action\" or configured_action_name == nil then\n    return false, false\n  end\n\n  self:warning(\"Unknown configured action: \"..tostring(configured_action_name))\n  return false, false\nend\n\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n----check for what should happend on the pir ON evnet\ncheck_pir_on_p1 = function()\n  profil_id_active = get_active_profile_id()\n  if profil_id_active == nil then return end\n  local configured_action_name = self.store.p1_on[profil_id_active]\n  execute_configured_light_action(configured_action_name, false)\n\n    local time = tonumber(self.store.p1_on_delay_time[profil_id_active]) or 300\n    if p1_pir_timer_delay_on ~= nil then\n      hub.clearTimeout(p1_pir_timer_delay_on)\n      p1_pir_timer_delay_on = nil\n    end\n    p1_pir_timer_delay_on = hub.setTimeout(time*1000, function()\n      p1_pir_timer_delay_on = nil\n      check_pir_on_delay_p1()\n    end)\nend\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n----check for what should happend on the pir ON delay evnet\ncheck_pir_on_delay_p1 = function()\n  profil_id_active = get_active_profile_id()\n  if profil_id_active == nil then return end\n  local configured_action_name = self.store.p1_on_delay[profil_id_active]\n  execute_configured_light_action(configured_action_name, false)\nend\n\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n----check for what should happend on the pir OFF evnet\ncheck_pir_off_p1 = function()\n  profil_id_active = get_active_profile_id()\n  if profil_id_active == nil then return end\n  local configured_action_name = self.store.p1_off[profil_id_active]\n  execute_configured_light_action(configured_action_name, false)\n\n  local time = tonumber(self.store.p1_off_delay_time[profil_id_active]) or 300\n  if p1_pir_timer_delay ~= nil then\n    hub.clearTimeout(p1_pir_timer_delay)\n    p1_pir_timer_delay = nil\n  end\n  p1_pir_timer_delay = hub.setTimeout(time*1000, function()\n    p1_pir_timer_delay = nil\n    check_pir_off_delay_p1()\n  end)\n\nend\n\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n----check for what should happend on the pir OFF delay evnet\ncheck_pir_off_delay_p1 = function()\n  profil_id_active = get_active_profile_id()\n  if profil_id_active == nil then return end\n  local configured_action_name = self.store.p1_off_delay[profil_id_active]\n  execute_configured_light_action(configured_action_name, false)\nend\n\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n----------------activeProfile--------------------------------------------------------------------------------\n----------------activeProfile--------------------------------------------------------------------------------\nEvent.id='_'                            \nEvent {type='profile',property='activeProfile'}            -----,value= profil_table_id[1]\nfunction Event:handler(event)\n  profil_id_active = tonumber(event.value) or get_active_profile_id()\n  if tonumber(profil_id_active) ~= nil then\n    if profil_id[tonumber(profil_id_active)] == nil then\n      profil_id[tonumber(profil_id_active)] = tonumber(profil_id_active)\n      profil_name[tonumber(profil_id_active)] = get_profile_display_name(profil_id_active)\n      refresh_profile_dropdown_options(false)\n      schedule_profile_metadata_refresh()\n    end\n    schedule_profile_cache_sync()\n  end\n  profile_info()\n  --self:debug(\"Profil value: \",event.value)\n  check_profile_cha()\nend\n\n--Event:post {type='profile',property='activeProfile'} -----------startup check\n\n\n\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n----check for what should happend on the pir ON evnet\ncheck_profile_cha = function()\n  local profile_id_for_change = get_active_profile_id()\n  if profile_id_for_change == nil then return end\n\n  cancel_profile_change_timers()\n\n  local function run_profile_change_action()\n    local configured_action_name = self.store.p1_cha[profile_id_for_change]\n    execute_configured_light_action(configured_action_name, true, profile_id_for_change)\n\n    local time = tonumber(self.store.p1_cha_delay_time[profile_id_for_change]) or 300\n    if time <= 0 then\n      check_profile_cha_delay(profile_id_for_change)\n      return\n    end\n\n    p1_profile_cha_delay = hub.setTimeout(time*1000, function()\n      p1_profile_cha_delay = nil\n      check_profile_cha_delay(profile_id_for_change)\n    end)\n  end\n\n  local time2 = tonumber(self.store.p1_priority_time[profile_id_for_change]) or 10\n  if time2 <= 0 then\n    run_profile_change_action()\n    return\n  end\n\n  p1_profile_priority = hub.setTimeout(time2*1000, function()\n    p1_profile_priority = nil\n    run_profile_change_action()\n  end)\nend\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n----check for what should happend on the pir ON delay evnet\ncheck_profile_cha_delay = function(profile_id_for_change)\n  local resolved_profile_id = tonumber(profile_id_for_change) or get_active_profile_id()\n  if resolved_profile_id == nil then return end\n  local configured_action_name = self.store.p1_cha_delay[resolved_profile_id]\n  execute_configured_light_action(configured_action_name, false)\nend\n\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n---all labels false\nlocal action_button_state = {}\nlocal action_button_names = {\n  \"turnoff\",\n  \"turnon\",\n}\n\nfor scene_number = 1, #scene_name_by_number do\n  table.insert(action_button_names, \"scene\"..scene_number..\"_set\")\n  table.insert(action_button_names, \"scene\"..scene_number..\"_set2\")\nend\n\nlocal action_button_name_lookup = {}\nfor _,button_name in ipairs(action_button_names) do\n  action_button_name_lookup[button_name] = true\nend\n\nlocal function normalize_active_button_name_list(candidate_active_button_names)\n  local normalized_active_button_name_list = {}\n  local normalized_active_button_name_lookup = {}\n\n  for _,button_name in ipairs(candidate_active_button_names or {}) do\n    button_name = tostring(button_name or \"\")\n    if action_button_name_lookup[button_name] == true and normalized_active_button_name_lookup[button_name] ~= true then\n      table.insert(normalized_active_button_name_list, button_name)\n      normalized_active_button_name_lookup[button_name] = true\n    end\n  end\n\n  return normalized_active_button_name_list\nend\n\nset_action_button_state = function(active_button_names)\n  local normalized_active_button_name_list = normalize_active_button_name_list(active_button_names)\n  local active_button_lookup = {}\n  for _,active_button_name in ipairs(normalized_active_button_name_list) do\n    active_button_lookup[active_button_name] = true\n  end\n\n  self.store.last_active_button_names = normalized_active_button_name_list\n\n  for _,button_name in ipairs(action_button_names) do\n    local should_be_active = active_button_lookup[button_name] == true\n    if action_button_state[button_name] ~= should_be_active then\n      self:updateView(button_name, \"value\", should_be_active and \"true\" or \"false\")\n      action_button_state[button_name] = should_be_active\n    end\n  end\nend\n\nbutton_labels_false = function()\n  set_action_button_state({})\nend\n\nlocal function build_section_header_markup(section_icon, section_title_text, section_description_text, top_left_markup)\n  local header_title_text = build_icon_text(section_icon, section_title_text)\n  local title_font_size = config.ui.infoLine.titleFontSize or (Fontsize + 2)\n  local description_font_size = config.ui.infoLine.descriptionFontSize or Fontsize\n  local section_header_markup = \"<table width=\"..config.ui.infoLine.widthPx..\"px border=0px>\"\n  if tostring(top_left_markup or \"\") ~= \"\" then\n    section_header_markup = section_header_markup..\"<tr><td align=left><font size='\"..description_font_size..\"'>\"..tostring(top_left_markup)..\"</font></td></tr>\"\n  end\n  section_header_markup = section_header_markup..\"<tr><td align=left>\"..color1..\"<font size='\"..title_font_size..\"'><b>\"..header_title_text..\"</b></font></td></tr>\"\n  if tostring(section_description_text or \"\") ~= \"\" then\n    section_header_markup = section_header_markup..\"<tr><td align=left>\"..color2..\"<font size='\"..description_font_size..\"'>\"..tostring(section_description_text)..\"</font></td></tr>\"\n  end\n  section_header_markup = section_header_markup..\"</table>\"\n  section_header_markup = section_header_markup..\"<hr width=\"..config.ui.infoLine.widthPx..\"px color=\"..color4..\" size=\"..config.ui.infoLine.sizePx..\"px />\"\n  return section_header_markup\nend\n\nlocal function refresh_section_header_labels()\n  local qa_version_markup = color1..tostring(config.qa_type or \"\")..\" \"..color2..\"Version: \"..tostring(config.version or \"\")\n  local quick_controls_header_markup = build_section_header_markup(\n    qa_ui_icons.scene,\n    \"Quick controls\",\n    \"Manual turn on, turn off, and direct scene activation.\"\n  )\n  local motion_enable_header_markup = build_section_header_markup(\n    qa_ui_icons.motion,\n    \"Motion enable\",\n    \"Enable or disable PIR-based light control for this QA.\",\n    qa_version_markup\n  )\n  local light_selection_header_markup = build_section_header_markup(\n    qa_ui_icons.light,\n    \"Light selection\",\n    \"Choose the lights to control, then press Save selected lights to apply the list.\"\n  )\n  local scene_snapshot_header_markup = build_section_header_markup(\n    qa_ui_icons.save,\n    \"Scene snapshots\",\n    \"Hold Save to store current light values. Press the scene button to apply the saved snapshot.\"\n  )\n  local motion_sensor_header_markup = build_section_header_markup(\n    qa_ui_icons.motion,\n    \"Trigger sensors\",\n    \"Choose which room motion, door, or window sensors should trigger events for this controller.\"\n  )\n  local profile_overview_header_markup = build_section_header_markup(\n    qa_ui_icons.profile,\n    \"Profile overview\",\n    \"Select a profile to inspect and edit the behavior used for that profile.\"\n  )\n  local profile_actions_header_markup = build_section_header_markup(\n    qa_ui_icons.timer,\n    \"Profile actions and timers\",\n    \"Configure PIR on, PIR off, profile change actions, and the related timers.\"\n  )\n  local setup_complete_header_markup = build_section_header_markup(\n    qa_ui_icons.confirm,\n    \"Setup complete\",\n    \"Use the buttons above to test scenes and verify motion behavior after configuration.\"\n  )\n\n  try_update_view_text(\"s0\", quick_controls_header_markup)\n  try_update_view_text(\"infoLine2\", motion_enable_header_markup)\n  try_update_view_text(\"infoLine4\", light_selection_header_markup)\n  try_update_view_text(\"infoLine5\", scene_snapshot_header_markup)\n  try_update_view_text(\"infoLine6\", motion_sensor_header_markup)\n  try_update_view_text(\"infoLine7\", profile_overview_header_markup)\n  try_update_view_text(\"infoLine8\", profile_actions_header_markup)\n  try_update_view_text(\"infoLine9\", setup_complete_header_markup)\nend\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n------update label for lines between the \"groups of functions in the QA view\"  \n\n\nupdate_selecteditem()\np1_on_info()\np1_off_info()\np1_cha_info()\np1_timeinfo()\nprofile_info()\nrefresh_static_ui_button_texts()\nset_action_button_state(self.store.last_active_button_names)\nrefresh_section_header_labels()\nif should_refresh_profile_metadata_after_startup == true then\n  schedule_profile_metadata_refresh()\nend\n---------------------------------------------------------------------------------------------------------------------\n---startup timer. \nself:debug(\"ID:\"..quickapp_id..\" Name; \"..self.name..\" has started in the room: \"..self_room_name..\"\")\nlocal endtime = os.clock()\nprint(\"\"..quickapp_id..\" Used: \", endtime-starttime,\"sec to start\")\n\nend --oninit\n"},{"name":"Translation","isMain":false,"isOpen":false,"content":"\n\n\n\n\nclass \"lang\"\nfunction lang:translation(language)\ntranslation = {\n  en = {\n    [\"Room Name: \"] = \"Room Name: \",\n    [\"Room ID: \"] = \"Room ID: \",\n    [\"Color Value is: \"] = \"Color Value is: \",\n    [\"Red\"] = \"Red\",\n    [\"Green\"] = \"Green\",\n    [\"Blue\"] = \"Blue\",\n    [\"white\"] = \"white\",\n    [\"Fire\"] = \"Fire\",\n    [\"Storm\"] = \"Storm\",\n    [\"RGB\"] = \"RGB\",\n    [\"Aurora\"] = \"Aurora\",\n    [\"Police\"] = \"Police\",\n    [\"No Program\"] = \"No Program\",\n    [\"Color Program is:\"] = \"Color Program is:\",\n    [\"Light Name: \"] = \"Light Name: \",\n    [\"Light Value: \"] = \"Light Value: \",\n    [\"Light id:\"] = \"Light id: \",\n    [\"Light\"] = \"Lights that is active: \",\n    [\"Pir Status is:\"] = \"Pir Status is:\",\n    [\"Safe\"] = \"Safe\",\n    [\"Detected\"] = \"Detected\",\n    [\"Active Profile is:\"] = \"Active Profile is:\",\n    [\"Change Delay\"] = \"Change Delay on Motion Sensor: \\n(not s2 inputs delay)\",\n    [\"Sensor timer is:\"] = \"Sensor timer is:\",\n    [\"Max time\"] = \"Max time 20min(+Deadband of sensor)\",\n    [\"Set fade\"] = \"Set fade rate and steps: \",\n    [\"Slow Off is:\"] = \"Slow Off is:\",\n    [\"Steps for Off: \"] = \"Steps for Off: \",\n    [\"Slow ON is: \"] = \"Slow ON is: \",\n    [\"Steps for ON: \"] = \"Steps for ON: \",\n    [\"Change: ON Steps\"] = \"Change: ON Steps\",\n    [\"Change: ON Time\"] = \"Change: ON Time\",\n    [\"Change: Off Steps\"] = \"Change: Off Steps\",\n    [\"Change: Off Time\"] = \"Change: Off Time\",\n    [\"Min\"] = \"Min\",\n    [\"Sec\"] = \"Sec\",\n    [\"Hold Down to save: \"] = \"Hold Down to save: \",\n    [\"turnOn\"] = \"Turn ON\",\n    [\"turnOff\"] = \"Turn OFF\",\n    [\"Turn ON slow\"] = \"Turn ON slow\",\n    [\"Turn OFF slow\"] = \"Turn OFF slow\",\n    [\"no_action\"] = \"No Action\",\n    [\"Setup for Profile:\"] = \"Setup for Profile:\",\n    [\"Pir ON\"] = \"Pir ON\",\n    [\"Pir ON Event\"] = \"Choose what should happen on <font color=green>Pir ON Event\",\n    [\"Pir OFF Event\"] = \"Choose what should happen on <font color=red>Pir OFF Event\",\n    [\"Pir OFF Event Delay\"] = \"Choose what should happen on <font color=red>Pir OFF Event Delay\",\n    [\"Change Delay Timer:\"] = \"Change Delay on:\\n<font color=red>Pir OFF Event Delay\\n<font color=orange>Delay OFF Timer is:\",\n    [\"Pir Trigger ON\"] = \"Pir Trigger ON is set to: \",\n    [\"Pir Trigger Delay ON\"] = \"Pir Trigger Delay ON is set to:\", \n    [\"Pir Trigger Delay\"] = \"Pir Trigger Time Delay is set to:\",\n    [\"Pir OFF\"] = \"Pir OFF\",\n    [\"Pir Trigger OFF\"] = \"Pir Trigger OFF is set to: \",\n    [\"Pir Trigger Delay OFF\"] = \"Pir Trigger Delay OFF is set to:\", \n    [\"Profile Change\"] = \"Profile Change\",\n    [\"Profile Change is\"] = \"Profile Change is set to: \",\n    [\"Profile Change Delay\"] = \"Profile Change Delay is set to: \",\n    [\"Profile Change Time\"] = \"Profile Change Time Delay is set to:\",\n    [\"Follow Pir Status\"] = \"Follow Pir Status\",\n    [\"Not follow Pir status\"] =   \"Not follow Pir status\",\n    [\"Motion Sensor Name: \"] = \"Motion Sensor Name: \",\n    [\"Motion Sensor id: \"] = \"Motion Sensor id: \",\n    [\"Motion Sensors\"] = \"Motion Sensors that is active: \",\n    [\"Profil this device\"] = \"Change Profile Only on this device:\",\n    [\"setup: Bedroom\"] = \"Setup: Bedroom\", \n    [\"setup: Hallway\"] = \"Setup: Hallway\", \n    [\"setup: Living Room\"] = \"Setup: Living Room\", \n    [\"Setup\"] = \"Setup basic motion profiles\", \n    [\"update\"] = \"Update IDs\",   \n    [\"enable\"] = \"Enable\",   \n    [\"disable\"] = \"Disable\",   \n    [\"info_pir_enable\"] = \"Hold down buttons to Enable or Disable the motionsensor events, Status:\",   \n    [\"info_pir_enable_on\"] = \"Pir Events Enabled\",  \n    [\"info_pir_enable_off\"] = \"Pir Events Disabled\",  \n    [\"follow_pir\"] = \"Follow Pir\",\n    [\"change\"] = \"Change\",\n    [\"setup profile\"] = \"Setup for Profile\",\n    [\"Basic Sensor Time\"] = \"Basic Sensor Time is\",\n    [\"Delay ON\"] = \"Delay ON Event Time is\",\n    [\"Delay OFF\"] = \"Delay OFF Event Time is\",\n    [\"Delay profile\"] = \"Delay Change Event Profile Time is\",\n    [\"Delay Priority\"] = \"Delay Change Priority Profile Time is\",\n    [\"Save\"] = \"Save\",   \n    [\"Setup profile below\"] = \"Setup profile below\",\n    [\"Change Priority Timer\"] = \"Change Priority Timer\", \n    [\"Change Delay Timer2\"] = \"Change Delay Timer\", \n    [\"Profile Change Event Delay\"] = \"Profile Change Event Delay\", \n    [\"Profile Change Event\"] = \"Profile Change Event\", \n    [\"OFF Delay Timer\"] = \"OFF Delay Timer\", \n    [\"Pir Off Event Delay2\"] = \"Pir Off Event Delay\", \n    [\"Pir Off Event2\"] = \"Pir Off Event\", \n    [\"ON Delay Timer\"] = \"ON Delay Timer\", \n    [\"Pir On Event Delay\"] = \"Pir On Event Delay\", \n    [\"Pir On Event2\"] = \"Pir On Event\", \n    [\"Basic Pir Timer\"] = \"Basic Pir Timer\", \n    \n    [\"Choose what should happen:\"] = \"Choose what should happen:\", \n    [\"Profile Change Events\"] = \"Profile Change Events\", \n    [\"Profile Change Delay Events\"] = \"Profile Change Delay Events\", \n    [\"and\"] = \"and\", \n\n\n    \n\n\n    },\n    no = {\n    [\"Room Name: \"] = \"Rom Navn: \",\n    [\"Room ID: \"] = \"Rom ID: \",\n    [\"Color Value is: \"] = \"Farge Nivå er: \",\n    [\"Red\"] = \"Rød\",\n    [\"Green\"] = \"Grønn\",\n    [\"Blue\"] = \"Blå\",\n    [\"white\"] = \"Hvit\",\n    [\"Fire\"] = \"Brann\",\n    [\"Storm\"] = \"Storm\",\n    [\"RGB\"] = \"RGB\",\n    [\"Aurora\"] = \"Aurora\",\n    [\"Police\"] = \"Politi\",\n    [\"No Program\"] = \"Ingen Program\",\n    [\"Color Program is:\"] = \"Farge Programmet er:\",\n    [\"Light Name: \"] = \"Lys Navn: \",\n    [\"Light Value: \"] = \"Lys Styrke: \",\n    [\"Light id:\"] = \"Lys id: \",\n    [\"Light\"] = \"Lys som er aktiv: \",\n    [\"Pir Status is:\"] = \"Pir Status er:\",\n    [\"Safe\"] = \"Ingen Bevegelse\",\n    [\"Detected\"] = \"Bevegelse\",\n    [\"Active Profile is:\"] = \"Aktiv Profil er:\",\n    [\"Change Delay\"] = \"Skift tiden på bevegelses sensoren: \\n(Ikke for s2 input sensor)\",\n    [\"Sensor timer is:\"] = \"Sensor tiden er:\",\n    [\"Max time\"] = \"Max tid er 20min(+dødbåndet av sensor)\",\n    [\"Set fade\"] = \"oppsett for tid og steg: \",\n    [\"Slow Off is:\"] = \"Sakte av er: \",\n    [\"Steps for Off: \"] = \"steg for sakte av: \",\n    [\"Slow ON is: \"] = \"Sakte på er: \",\n    [\"Steps for ON: \"] = \"steg for sakte på: \",\n    [\"Change: ON Steps\"] = \"Endre: På Steg\",\n    [\"Change: ON Time\"] = \"Endre: På Tid\",\n    [\"Change: Off Steps\"] = \"Endre: AV Steg\",\n    [\"Change: Off Time\"] = \"Endre: Av Tid\",\n    [\"Min\"] = \"Min\",\n    [\"Sec\"] = \"Sec\",\n    [\"Hold Down to save: \"] = \"Hold for å lagre: \",\n    [\"turnOn\"] = \"Skru På\",\n    [\"turnOff\"] = \"Skru Av\",\n    [\"Turn ON slow\"] = \"Skru På Sakte\",\n    [\"Turn OFF slow\"] = \"Skru Av Sakte\",\n    [\"no_action\"] = \"Ingen ting\",\n    [\"Setup for Profile:\"] = \"Oppsett for Profil:\",\n    [\"Pir ON\"] = \"Pir På\",\n    [\"Pir ON Event\"] = \"Velg hva som skjer ved Pir går På Event\",\n    [\"Pir OFF Event\"] = \"Velg hva som skjer ved Pir går Av Event\",\n    [\"Pir OFF Event Delay\"] = \"Velg hva som skjer ved Pir går Av Event med forsinkelse\",\n    [\"Change Delay Timer:\"] = \"Skift forsinkelse for:\\n<font color=red>Pir AV Event Forsinkelse\\n<font color=orange>Forsinkelse AV Timer er:\",\n    [\"Pir Trigger ON\"] = \"Pir aktiv På er satt til: \",\n    [\"Pir Trigger Delay ON\"] = \"Pir aktiv forsinkelse På er satt til: \", \n    [\"Pir Trigger Delay\"] = \"Pir aktiv tids forsinkelse er satt til:\",\n    [\"Pir OFF\"] = \"Pir Av\",\n    [\"Pir Trigger OFF\"] = \"Pir inaktiv Av er satt til: \",\n    [\"Pir Trigger Delay OFF\"] = \"Pir inaktiv forsinkelse Av er satt til: \", \n    [\"Profile Change\"] = \"Profil Skifte\",\n    [\"Profile Change is\"] = \"Profil Skifte er satt til: \",\n    [\"Profile Change Delay\"] = \"Profil Skifte forsinkelse er satt til: \",\n    [\"Profile Change Time\"] = \"Profil Skifte tids forsinkelse er satt til:\",\n    [\"Follow Pir Status\"] = \"Følg Pir Status\",\n    [\"Not follow Pir status\"] =   \"ikke Følg Pir status\",\n    [\"Motion Sensor Name: \"] = \"Pir Sensor Navn: \",\n    [\"Motion Sensor id: \"] = \"Pir Sensor ID: \",\n    [\"Motion Sensors\"] = \"Pir Sensors som er aktive: \",\n    [\"Profil this device\"] = \"Skift Profil kun på denne enheten: \",\n    [\"setup: Bedroom\"] = \"Oppsett: Soverom\", \n    [\"setup: Hallway\"] = \"Oppsett: Vindfang\", \n    [\"setup: Living Room\"] = \"Oppsett: Stue\", \n    [\"Setup\"] = \"Oppsett for standard Profiler\", \n    [\"update\"] = \"Oppdater ID\", \n    [\"enable\"] = \"Aktiver\",   \n    [\"disable\"] = \"Deaktiver\",   \n    [\"info_pir_enable\"] = \"Hold ned Kanppene for å Aktiver eller Deaktiver Bevegelsessensor Events, Status:\",   \n    [\"info_pir_enable_on\"] = \"Pir Events Aktivert\",  \n    [\"info_pir_enable_off\"] = \"Pir Events Deaktivert\",  \n    [\"follow_pir\"] = \"Følg Pir\",\n    [\"change\"] = \"Skift\",\n    [\"setup profile\"] = \"Oppsett for Profiler\",\n    [\"Basic Sensor Time\"] = \"Standard Tid for sensor\",\n    [\"Delay ON\"] = \"Forsinkelse På Tid er\",\n    [\"Delay OFF\"] = \"Forsinkelse Av Tid er\",\n    [\"Delay profile\"] = \"Forsinkelse ved profil skifte er\",\n    [\"Delay Priority\"] = \"Forsinkelse ved profil prioritet skifte er\",\n    [\"Setup profile below\"] = \"Oppsett for profiler under her\",\n    [\"Change Priority Timer\"] = \"Skift Prioritets timer\", \n    [\"Change Delay Timer2\"] = \"Profil Skift Forsinkelses Timer\", \n    [\"Profile Change Event Delay\"] = \"Profile Skift Event Forsinkelse\", \n    [\"Profile Change Event\"] = \"Profile Skifte Event\", \n    [\"OFF Delay Timer\"] = \"Av forsinkelses Timer\", \n    [\"Pir Off Event Delay2\"] = \"Pir Av Event forsinkelse\", \n    [\"Pir Off Event2\"] = \"Pir Av Event\", \n    [\"ON Delay Timer\"] = \"På Forsinkelses Timer\", \n    [\"Pir On Event Delay\"] = \"Pir På Event Forsinkelse\", \n    [\"Pir On Event2\"] = \"Pir På Event\", \n    [\"Basic Pir Timer\"] = \"Standard Pir Timer\", \n    [\"Save\"] = \"Lagre\", \n\n    [\"Choose what should happen:\"] = \"Velg hva som skal skje:\", \n    [\"Profile Change Events\"] = \"Profil Skifte Event\", \n    [\"Profile Change Delay Events\"] = \"Profil Skifte forsinekelse Event\", \n    [\"and\"] = \"og\", \n\n\n\n\n    },\n    de = {\n    [\"Room Name: \"] = \"Raumname: \",\n    [\"Room ID: \"] = \"Raum ID: \",\n    [\"Color Value is: \"] = \"Farbwert ist: \",\n    [\"Red\"] = \"Rot\",\n    [\"Green\"] = \"Grün\",\n    [\"Blue\"] = \"Blau\",\n    [\"white\"] = \"Weiß\",\n    [\"Fire\"] = \"Feuer\",\n    [\"Storm\"] = \"Sturm\",\n    [\"RGB\"] = \"RGB\",\n    [\"Aurora\"] = \"Aurora\",\n    [\"Police\"] = \"Polizei\",\n    [\"No Program\"] = \"Kein Programm\",\n    [\"Color Program is:\"] = \"Farbprogramm ist:\",\n    [\"Light Name: \"] = \"Lichtname: \",\n    [\"Light Value: \"] = \"Lichtwert: \",\n    [\"Light id:\"] = \"Licht ID: \",\n    [\"Light\"] = \"Aktives Licht: \",\n    [\"Pir Status is:\"] = \"Pir Status ist:\",\n    [\"Safe\"] = \"Sicher\",\n    [\"Detected\"] = \"Erkannt\",\n    [\"Active Profile is:\"] = \"Aktives Profil ist:\",\n    [\"Change Delay\"] = \"Ändern der Verzögerung am Bewegungssensor: \\n(nicht s2 Eingangsverzögerung)\",\n    [\"Sensor timer is:\"] = \"Sensorzeit ist:\",\n    [\"Max time\"] = \"Max Zeit 20min(+Blindzeit des Sensors)\",\n    [\"Set fade\"] = \"Setzen von Ausblenderate und -schritte: \",\n    [\"Slow Off is:\"] = \"Langsam Ausschalten ist:\",\n    [\"Steps for Off: \"] = \"Schritte fürs Ausschalten: \",\n    [\"Slow ON is: \"] = \"Langsam Anschalten ist: \",\n    [\"Steps for ON: \"] = \"Schritte fürs Anschalten: \",\n    [\"Change: ON Steps\"] = \"Ändern: Schritte fürs Anschalten\",\n    [\"Change: ON Time\"] = \"Ändern: Anschaltzeit\",\n    [\"Change: Off Steps\"] = \"Ändern: Schritte fürs Ausschalten\",\n    [\"Change: Off Time\"] = \"Ändern: Ausschaltzeit\",\n    [\"Min\"] = \"Min\",\n    [\"Sec\"] = \"Sek\",\n    [\"Hold Down to save: \"] = \"Halten zum Speichern: \",\n    [\"turnOn\"] = \"Anschalten\",\n    [\"turnOff\"] = \"Ausschalten\",\n    [\"Turn ON slow\"] = \"Langsam Anschalten\",\n    [\"Turn OFF slow\"] = \"Langsam Ausschalten\",\n    [\"no_action\"] = \"Keine Aktion\",\n    [\"Setup for Profile:\"] = \"Setup für Profil:\",\n    [\"Pir ON\"] = \"Pir An\",\n    [\"Pir ON Event\"] = \"Auswählen was passieren soll bei <font color=green>Pir An Event\",\n    [\"Pir OFF Event\"] = \"Auswählen was passieren soll bei <font color=red>Pir Aus Event\",\n    [\"Pir OFF Event Delay\"] = \"Auswählen was passieren soll bei <font color=red>Pir Aus Event 